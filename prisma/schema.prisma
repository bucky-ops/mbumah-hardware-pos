// MBUMAH HARDWARE POS & ERP - Prisma Schema
// Multi-tenant via storeId discriminator. PostgreSQL for production (Vercel + Neon).
//
// This schema uses PostgreSQL as the default provider.
// For local development:
//   1. Set DATABASE_URL and DIRECT_URL in .env to your local or Neon database
//   2. Run: npx prisma db push && npx prisma db seed
//
// Notes:
//   - IDs use cuid() for cross-DB compat
//   - Monetary fields are Float; migrate to Decimal for production
//   - JSON metadata stored as String; switch to Json type on PostgreSQL

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// TENANCY & ORGANIZATION
model Organization {
  id          String   @id @default(cuid())
  name        String
  taxPin      String?  // KRA PIN for Kenyan businesses
  status      String   @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stores      Store[]
  users       User[]
  accounts    Account[]

  @@map("organizations")
}

model Store {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  location        String?
  address         String?
  phone           String?
  email           String?
  taxPin          String?  // Store-level KRA PIN
  status          String   @default("ACTIVE") // ACTIVE, CLOSED, RENOVATING
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  categories      ProductCategory[]
  customers       Customer[]
  transactions    SalesTransaction[]
  payments        Payment[]
  debtLedgers     DebtLedger[]
  debtPayments    DebtPayment[]
  rentals         EquipmentRental[]
  stockMovements  StockMovement[]
  warehouseStocks WarehouseStock[]
  journalEntries  JournalEntry[]
  systemLogs      SystemLog[]
  cashDrawerLogs  CashDrawerLog[]
  receipts        Receipt[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  expenses        Expense[]
  shifts          Shift[]
  giftCards       GiftCard[]
  deliveryNotes   DeliveryNote[]
  invoices        Invoice[]
  customerCredits CustomerCredit[]
  vouchers        Voucher[]
  voucherCampaigns VoucherCampaign[]
  bankAccounts    BankAccount[]
  mpesaReconciliations MpesaReconciliation[]
  loyaltyTiers    LoyaltyTier[]
  loyaltyTransactions LoyaltyTransaction[]
  loyaltyCampaigns LoyaltyCampaign[]
  taxCategories   TaxCategory[]
  taxFilings      TaxFiling[]
  expenseBudgets  ExpenseBudget[]
  customerInteractions CustomerInteraction[]
  transfersFrom   StoreTransfer[]   @relation("TransferFrom")
  transfersTo     StoreTransfer[]   @relation("TransferTo")
  messages        Message[]

  @@index([organizationId])
  @@map("stores")
}

// AUTHENTICATION & RBAC

model User {
  id              String   @id @default(cuid())
  organizationId  String
  storeId         String?
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("SALES_PERSON") // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, SALES_PERSON, ACCOUNTANT
  phone           String?
  avatarUrl       String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store           Store?       @relation(fields: [storeId], references: [id])
  sessions        Session[]
  systemLogs      SystemLog[]
  transactions    SalesTransaction[]
  cashDrawerLogs  CashDrawerLog[]
  shifts          Shift[]

  @@index([organizationId])
  @@index([storeId])
  @@index([email])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         String   // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, SALES_PERSON, ACCOUNTANT
  resource     String   // products, transactions, customers, financials, rentals, admin, reports
  action       String   // create, read, update, delete, approve, refund, export
  createdAt    DateTime @default(now())

  @@unique([role, resource, action])
  @@map("role_permissions")
}

// PRODUCT & INVENTORY

model ProductCategory {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  description     String?
  icon            String?
  color           String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products        Product[]
  subCategories   SubCategory[]

  @@index([storeId])
  @@map("product_categories")
}

model SubCategory {
  id              String   @id @default(cuid())
  categoryId      String
  name            String
  description     String?
  icon            String?
  color           String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products        Product[]

  @@index([categoryId])
  @@map("sub_categories")
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  categoryId        String?
  subCategoryId     String?
  sku               String   @unique
  barcode           String?  @unique
  name              String
  description       String?
  unitType          String   @default("PIECE") // PIECE, KILOGRAM, METER, LITER, BAG, BOX, SET
  quantityInStock   Float    @default(0)
  reorderLevel      Float    @default(10)
  pricePerUnit      Float    // Selling price
  costPrice         Float    // Purchase/cost price
  taxRate           Float    @default(16) // Kenya VAT 16%
  isRental          Boolean  @default(false)
  isBundle          Boolean  @default(false)
  isActive          Boolean  @default(true)
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category          ProductCategory? @relation(fields: [categoryId], references: [id])
  subCategory       SubCategory?     @relation(fields: [subCategoryId], references: [id])
  bundleItems       ProductBundle[]  @relation("BundleParent")
  parentBundles     ProductBundle[]  @relation("BundleChild")
  saleItems         SaleItem[]
  stockMovements    StockMovement[]
  warehouseStocks   WarehouseStock[]
  rentals           EquipmentRental[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems      InvoiceItem[]
  transferItems     StoreTransferItem[]

  @@index([storeId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([isActive])
  @@map("products")
}

model ProductBundle {
  id                String   @id @default(cuid())
  parentProductId   String   // The bundle product
  childProductId    String   // The constituent product
  quantityRequired  Float    @default(1) // How many of child in one bundle

  parentProduct     Product  @relation("BundleParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  childProduct      Product  @relation("BundleChild", fields: [childProductId], references: [id], onDelete: Cascade)

  @@unique([parentProductId, childProductId])
  @@index([parentProductId])
  @@map("product_bundles")
}

model WarehouseStock {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  warehouse   String   @default("MAIN") // MAIN, BACKUP, RECEIVING
  quantity    Float    @default(0)
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, warehouse])
  @@index([storeId])
  @@map("warehouse_stocks")
}

model StockMovement {
  id              String   @id @default(cuid())
  storeId         String
  productId       String
  movementType    String   // PURCHASE, SALE, ADJUSTMENT, TRANSFER, RETURN, RENTAL_OUT, RENTAL_RETURN
  quantity        Float    // Positive for in, negative for out
  referenceId     String?  // Transaction ID, PO ID, etc.
  notes           String?
  performedBy     String?  // User ID
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

// CUSTOMERS & CRM

model Customer {
  id                  String   @id @default(cuid())
  storeId             String
  name                String
  phone               String?
  email               String?
  address             String?
  idNumber            String?  // Kenyan National ID
  currentDebtBalance  Float    @default(0)
  debtLimit           Float    @default(50000) // KES default limit
  loyaltyPoints       Int      @default(0)
  totalPurchases      Float    @default(0) // Total amount purchased - for gift card tracking
  totalSpent          Float    @default(0) // Total amount actually paid
  purchaseCount       Int      @default(0) // Number of purchases
  preferredChannel    String   @default("SMS") // SMS, EMAIL, WHATSAPP, PRINT
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store               Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedgers         DebtLedger[]
  transactions        SalesTransaction[]
  rentals             EquipmentRental[]
  giftCards           GiftCard[]
  customerCredits     CustomerCredit[]
  loyaltyProfile      CustomerLoyalty[]
  loyaltyTransactions LoyaltyTransaction[]
  interactions        CustomerInteraction[]

  @@index([storeId])
  @@index([phone])
  @@index([name])
  @@map("customers")
}

// SALES & TRANSACTIONS

model SalesTransaction {
  id              String   @id @default(cuid())
  storeId         String
  receiptNumber   String   @unique
  customerId      String?
  customerPhone   String?  // Customer phone for quick checkout
  cashierId       String
  subtotal        Float
  taxAmount       Float
  discountAmount  Float    @default(0)
  totalAmount     Float
  paymentMethod   String   // CASH, MPESA, DEBT, SPLIT
  paymentStatus   String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED, PARTIAL
  transactionType String   @default("SALE") // SALE, REFUND, VOID
  notes           String?
  isOffline       Boolean  @default(false)
  syncedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer?   @relation(fields: [customerId], references: [id])
  cashier         User        @relation(fields: [cashierId], references: [id])
  items           SaleItem[]
  payments        Payment[]
  debtLedgers     DebtLedger[]
  receipt         Receipt?
  deliveryNote    DeliveryNote?

  @@index([storeId])
  @@index([cashierId])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("sales_transactions")
}

model SaleItem {
  id              String   @id @default(cuid())
  transactionId   String
  productId       String
  productName     String   // Snapshot at time of sale
  quantity        Float
  unitType        String
  pricePerUnit    Float
  costPrice       Float    // Snapshot for profit calculation
  discountPercent Float    @default(0)
  taxRate         Float    @default(16)
  lineTotal       Float
  isRentalItem    Boolean  @default(false)

  transaction     SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("sale_items")
}

// PAYMENTS

model Payment {
  id              String   @id @default(cuid())
  storeId         String
  transactionId   String
  paymentMethod   String   // CASH, MPESA, DEBT
  amount          Float
  currency        String   @default("KES")
  status          String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED
  reference       String?  // M-Pesa CheckoutRequestID, receipt number, etc.
  metadata        String?  // JSON string for additional payment details
  processedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([transactionId])
  @@index([paymentMethod])
  @@map("payments")
}

model MpesaTransaction {
  id                    String   @id @default(cuid())
  storeId               String
  checkoutRequestId     String?
  merchantRequestId     String?
  mpesaReceiptNumber    String?
  phoneNumber           String?
  amount                Float
  status                String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  resultCode            String?
  resultDesc            String?
  callbackReceived      Boolean  @default(false)
  transactionId         String?  // Link to SalesTransaction
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([storeId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("mpesa_transactions")
}

// DEBT / CREDIT MANAGEMENT

model DebtLedger {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  transactionId   String?
  amountOwed      Float
  amountPaid      Float    @default(0)
  balance         Float    // amountOwed - amountPaid
  dueDate         DateTime
  status          String   @default("OUTSTANDING") // OUTSTANDING, PARTIAL, SETTLED, OVERDUE, WRITTEN_OFF
  agingBucket     String   @default("CURRENT") // CURRENT, DAYS_30, DAYS_60, DAYS_90_PLUS
  lastReminderAt  DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer          @relation(fields: [customerId], references: [id])
  transaction     SalesTransaction? @relation(fields: [transactionId], references: [id])
  debtPayments    DebtPayment[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([agingBucket])
  @@index([dueDate])
  @@map("debt_ledgers")
}

model DebtPayment {
  id              String   @id @default(cuid())
  storeId         String
  debtLedgerId    String
  amount          Float
  paymentMethod   String   // CASH, MPESA
  reference       String?
  receivedBy      String?  // User ID
  createdAt       DateTime @default(now())

  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedger      DebtLedger  @relation(fields: [debtLedgerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([debtLedgerId])
  @@map("debt_payments")
}

// EQUIPMENT RENTAL

model EquipmentRental {
  id                  String   @id @default(cuid())
  storeId             String
  productId           String
  customerId          String
  status              String   @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE, DAMAGED, LOST
  rentalStartDate     DateTime @default(now())
  expectedReturnDate  DateTime
  actualReturnDate    DateTime?
  securityDeposit     Float
  ratePerDay          Float
  ratePerWeek         Float?
  ratePerMonth        Float?
  totalRentalCharge   Float    @default(0)
  lateFeeAccumulated  Float    @default(0)
  damageAssessment    String?  // NONE, MINOR, MODERATE, SEVERE
  damageCharge        Float    @default(0)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])
  customer            Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([expectedReturnDate])
  @@map("equipment_rentals")
}

// FINANCIAL ACCOUNTING - DOUBLE-ENTRY BOOKKEEPING

model Account {
  id              String   @id @default(cuid())
  organizationId  String
  code            String   // Account code e.g. 1000, 2000, 3000
  name            String
  type            String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType         String?  // CURRENT_ASSET, FIXED_ASSET, CURRENT_LIABILITY, etc.
  normalBalance   String   @default("DEBIT") // DEBIT, CREDIT
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalEntryLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([type])
  @@map("accounts")
}

model JournalEntry {
  id              String   @id @default(cuid())
  storeId         String
  entryNumber     String   @unique
  entryDate       DateTime @default(now())
  description     String
  referenceType   String?  // SALE, PAYMENT, REFUND, RENTAL, ADJUSTMENT
  referenceId     String?  // Transaction ID, Payment ID, etc.
  totalDebit      Float
  totalCredit     Float
  isPosted        Boolean  @default(false)
  postedAt        DateTime?
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  lines           JournalEntryLine[]

  @@index([storeId])
  @@index([entryDate])
  @@index([referenceType])
  @@index([isPosted])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String   @id @default(cuid())
  journalEntryId  String
  accountId       String
  debit           Float    @default(0)
  credit          Float    @default(0)
  description     String?
  createdAt       DateTime @default(now())

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// CASH DRAWER MANAGEMENT

model CashDrawerLog {
  id              String   @id @default(cuid())
  storeId         String
  userId          String
  action          String   // OPEN, CLOSE, CASH_IN, CASH_OUT, SALE, REFUND
  amount          Float
  balance         Float    // Running balance
  notes           String?
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@map("cash_drawer_logs")
}

// RECEIPTS

model Receipt {
  id              String   @id @default(cuid())
  storeId         String
  transactionId   String   @unique
  receiptNumber   String   @unique
  receiptType     String   @default("DIGITAL") // DIGITAL, PRINTED, EMAIL, SMS, WHATSAPP
  sentTo          String?  // Phone or email
  sentAt          DateTime?
  createdAt       DateTime @default(now())

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction  @relation(fields: [transactionId], references: [id])

  @@index([storeId])
  @@index([transactionId])
  @@map("receipts")
}

// SUPPLIER & PURCHASE ORDERS

model Supplier {
  id            String   @id @default(cuid())
  storeId       String
  name          String
  email         String?
  phone         String?
  address       String?
  city          String?
  contactPerson String?
  taxPin        String?
  paymentTerms  String   @default("NET_30") // NET_15, NET_30, NET_60, IMMEDIATE
  rating        Int      @default(3) // 1-5 stars
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([storeId])
  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  storeId         String
  poNumber        String   @unique
  supplierId      String
  status          String   @default("DRAFT") // DRAFT, SENT, CONFIRMED, RECEIVED, CANCELLED
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  totalAmount     Float    @default(0)
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store           @relation(fields: [storeId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  receivedQty     Float    @default(0)
  notes           String?

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// EXPENSES

model Expense {
  id              String   @id @default(cuid())
  storeId         String
  description     String
  amount          Float
  category        String   // RENT, SALARIES, UTILITIES, TRANSPORT, MAINTENANCE, SUPPLIES, OTHER
  paidBy          String   // User ID who paid
  paymentMethod   String   @default("CASH") // CASH, MPESA
  journalEntryId  String?  // Reference to the created journal entry
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([category])
  @@index([paidBy])
  @@index([createdAt])
  @@map("expenses")
}

// SYSTEM LOGGING & AUDIT

model SystemLog {
  id              String   @id @default(cuid())
  storeId         String?
  userId          String?
  action          String
  component       String   // POS, INVENTORY, FINANCIAL, AUTH, PAYMENT, RENTAL
  severity        String   @default("INFO") // DEBUG, INFO, WARN, ERROR, CRITICAL
  message         String
  metadata        String?  // JSON string for additional context
  stackTrace      String?
  ipAddress       String?
  createdAt       DateTime @default(now())

  store           Store?   @relation(fields: [storeId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([component])
  @@index([severity])
  @@index([createdAt])
  @@map("system_logs")
}

// SYSTEM CONFIGURATION

model SystemConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  isEncrypted     Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("system_configs")
}

model InitializationLog {
  id              String   @id @default(cuid())
  event           String
  details         String?
  executedAt      DateTime @default(now())

  @@map("initialization_logs")
}

// SHIFT MANAGEMENT

model Shift {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id])
  storeId           String    @map("store_id")
  store             Store     @relation(fields: [storeId], references: [id])
  startedAt         DateTime  @map("started_at") @default(now())
  endedAt           DateTime? @map("ended_at")
  startingCash      Float     @map("starting_cash") @default(0)
  endingCash        Float?    @map("ending_cash")
  countedCash       Float?    @map("counted_cash")
  cashDifference    Float?    @map("cash_difference")
  totalSales        Float     @map("total_sales") @default(0)
  totalTransactions Int       @map("total_transactions") @default(0)
  status            String    @default("ACTIVE") // ACTIVE, ENDED
  notes             String?
  createdAt         DateTime  @map("created_at") @default(now())
  updatedAt         DateTime  @map("updated_at") @updatedAt

  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@map("shifts")
}

// GIFT CARDS & LOYALTY

model GiftCard {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String?
  code            String   @unique // Gift card code
  initialBalance  Float    // Starting balance
  currentBalance  Float    // Remaining balance
  status          String   @default("ACTIVE") // ACTIVE, REDEEMED, EXPIRED, CANCELLED
  issuedReason    String   @default("LOYALTY") // LOYALTY, PROMOTION, PURCHASE, GIFT, REFERRAL
  minimumPurchase Float    @default(0) // Min purchase amount to qualify
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([code])
  @@index([status])
  @@map("gift_cards")
}

// DELIVERY NOTES

model DeliveryNote {
  id                String   @id @default(cuid())
  storeId           String
  transactionId     String?  @unique // Link to sales transaction
  deliveryNumber    String   @unique
  customerId        String?
  customerName      String
  customerPhone     String?
  deliveryAddress   String?
  driverName        String?
  vehicleNumber     String?
  status            String   @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED, CANCELLED
  scheduledDate     DateTime?
  deliveredAt       DateTime?
  notes             String?
  createdBy         String?  // User ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store             Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction       SalesTransaction? @relation(fields: [transactionId], references: [id])
  items             DeliveryNoteItem[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([deliveryNumber])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  productId       String?
  productName     String
  quantity        Float
  unitType        String   @default("PIECE")
  notes           String?

  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([deliveryNoteId])
  @@map("delivery_note_items")
}

// INVOICES & QUOTATIONS

model Invoice {
  id              String   @id @default(cuid())
  storeId         String
  invoiceNumber   String   @unique
  invoiceType     String   @default("INVOICE") // INVOICE, QUOTATION, PROFORMA, CREDIT_NOTE, DEBIT_NOTE
  customerId      String?
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  issueDate       DateTime @default(now())
  dueDate         DateTime?
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, INVOICED, PAID, CANCELLED, EXPIRED
  transactionId   String?  // Link to sales transaction if converted
  notes           String?
  terms           String?
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]

  @@index([storeId])
  @@index([customerId])
  @@index([invoiceType])
  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  productId       String?
  productName     String
  description     String?
  quantity        Float
  unitType        String   @default("PIECE")
  pricePerUnit    Float
  discountPercent Float    @default(0)
  taxRate         Float    @default(16)
  lineTotal       Float

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

// CUSTOMER CREDITS

model CustomerCredit {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  amount          Float
  creditType      String   @default("CREDIT") // CREDIT, DEBIT, ADJUSTMENT, REFUND
  reference       String?  // Invoice number, transaction ID, etc.
  description     String?
  balance         Float    // Running balance after this entry
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([creditType])
  @@index([createdAt])
  @@map("customer_credits")
}

// ============================================================
// VOUCHER MANAGEMENT
// ============================================================

model Voucher {
  id              String   @id @default(cuid())
  storeId         String
  code            String   @unique
  voucherType     String   @default("FIXED") // FIXED, PERCENTAGE, FREE_PRODUCT, BUNDLE
  name            String
  description     String?
  value           Float    // Fixed amount or percentage value
  minimumPurchase Float    @default(0)
  maxDiscount     Float?   // Cap for percentage discounts
  freeProductId   String?  // For FREE_PRODUCT type
  maxUses         Int      @default(1) // Total allowed uses
  currentUses     Int      @default(0)
  maxUsesPerUser  Int      @default(1)
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, EXPIRED, CANCELLED
  campaignId      String?  // Link to campaign
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  redemptions     VoucherRedemption[]
  campaign        VoucherCampaign?  @relation(fields: [campaignId], references: [id])

  @@index([storeId])
  @@index([code])
  @@index([status])
  @@index([voucherType])
  @@map("vouchers")
}

model VoucherCampaign {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  description     String?
  campaignType    String   @default("PROMOTION") // PROMOTION, SEASONAL, LOYALTY, REFERRAL, FLASH_SALE
  startDate       DateTime
  endDate         DateTime?
  budget          Float    @default(0)
  spentAmount     Float    @default(0)
  targetAudience  String?  // ALL, NEW_CUSTOMERS, RETURNING, LOYALTY_TIER
  status          String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  totalRedemptions Int     @default(0)
  totalRevenue    Float    @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vouchers        Voucher[]

  @@index([storeId])
  @@index([status])
  @@map("voucher_campaigns")
}

model VoucherRedemption {
  id              String   @id @default(cuid())
  voucherId       String
  transactionId   String?
  customerId      String?
  redeemedBy      String?  // User ID who processed
  discountAmount  Float
  originalTotal   Float
  finalTotal      Float
  createdAt       DateTime @default(now())

  voucher         Voucher  @relation(fields: [voucherId], references: [id])

  @@index([voucherId])
  @@index([customerId])
  @@index([createdAt])
  @@map("voucher_redemptions")
}

// ============================================================
// BANKING & RECONCILIATION
// ============================================================

model BankAccount {
  id              String   @id @default(cuid())
  storeId         String
  bankName        String
  accountName     String
  accountNumber   String
  branch          String?
  swiftCode       String?
  currency        String   @default("KES")
  openingBalance  Float    @default(0)
  currentBalance  Float    @default(0)
  accountType     String   @default("CHECKING") // CHECKING, SAVINGS, MPESA, PETTY_CASH
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions    BankTransaction[]
  reconciliations BankReconciliation[]

  @@index([storeId])
  @@index([accountType])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  transactionType String   @default("DEPOSIT") // DEPOSIT, WITHDRAWAL, TRANSFER, FEE, INTEREST
  amount          Float
  balanceAfter    Float    // Running balance after transaction
  reference       String?  // Cheque number, transfer reference, M-Pesa ref
  description     String?
  transactionDate DateTime @default(now())
  isReconciled    Boolean  @default(false)
  reconciliationId String? // Link to reconciliation
  journalEntryId  String?  // Link to journal entry
  createdAt       DateTime @default(now())

  bankAccount     BankAccount        @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliation  BankReconciliation? @relation(fields: [reconciliationId], references: [id])

  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
  @@map("bank_transactions")
}

model BankReconciliation {
  id              String   @id @default(cuid())
  bankAccountId   String
  statementDate   DateTime
  statementBalance Float
  bookBalance     Float
  difference      Float
  status          String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, APPROVED
  notes           String?
  approvedBy      String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccount     BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  transactions    BankTransaction[]

  @@index([bankAccountId])
  @@index([status])
  @@map("bank_reconciliations")
}

model MpesaReconciliation {
  id              String   @id @default(cuid())
  storeId         String
  mpesaReceipt    String?
  phoneNumber     String?
  amount          Float
  transactionDate DateTime
  status          String   @default("PENDING") // PENDING, MATCHED, UNMATCHED, DISPUTED
  matchedTransactionId String? // Link to SalesTransaction payment
  matchedAt       DateTime?
  notes           String?
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([status])
  @@index([mpesaReceipt])
  @@map("mpesa_reconciliations")
}

// ============================================================
// LOYALTY PROGRAM - TIER STRUCTURE
// ============================================================

model LoyaltyTier {
  id              String   @id @default(cuid())
  storeId         String
  name            String   // Bronze, Silver, Gold, Platinum
  minPoints       Int      @default(0)
  maxPoints       Int?     // null = no upper limit
  discountPercent Float    @default(0) // Tier discount percentage
  pointsMultiplier Float   @default(1) // Points earning multiplier
  benefits        String?  // JSON string of benefits
  color           String   @default("#6B7280") // Tier color
  icon            String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerTiers   CustomerLoyalty[]

  @@index([storeId])
  @@index([sortOrder])
  @@map("loyalty_tiers")
}

model CustomerLoyalty {
  id              String   @id @default(cuid())
  customerId      String
  tierId          String
  pointsBalance   Int      @default(0)
  lifetimePoints  Int      @default(0)
  totalRedeemed   Int      @default(0)
  tierAchievedAt  DateTime @default(now())
  lastActivityAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer     @relation(fields: [customerId], references: [id])
  tier            LoyaltyTier  @relation(fields: [tierId], references: [id])

  @@index([customerId])
  @@index([tierId])
  @@map("customer_loyalty")
}

model LoyaltyTransaction {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  points          Int      // Positive = earned, Negative = redeemed
  transactionType String   @default("EARN") // EARN, REDEEM, BONUS, EXPIRE, ADJUST
  reference       String?  // Transaction ID, manual reference, etc.
  description     String?
  createdBy       String?
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model LoyaltyCampaign {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  description     String?
  campaignType    String   @default("BONUS_POINTS") // BONUS_POINTS, DOUBLE_POINTS, TIER_UPGRADE, SPECIAL_EVENT
  bonusPoints     Int      @default(0)
  multiplier      Float    @default(1)
  startDate       DateTime
  endDate         DateTime?
  targetTierId    String?  // Target specific tier
  status          String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  totalPointsAwarded Int   @default(0)
  totalParticipants  Int   @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([status])
  @@map("loyalty_campaigns")
}

// ============================================================
// TAX MANAGEMENT / eTIMS
// ============================================================

model TaxCategory {
  id              String   @id @default(cuid())
  storeId         String
  name            String   // VAT, WHT, SERVICE_CHARGE, EXCISE
  rate            Float    // Percentage rate
  description     String?
  etimsCode       String?  // eTIMS tax category code
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  taxRates        TaxRate[]

  @@index([storeId])
  @@index([etimsCode])
  @@map("tax_categories")
}

model TaxRate {
  id              String   @id @default(cuid())
  taxCategoryId   String
  name            String   // Standard VAT 16%, Reduced Rate 8%, Zero Rate, Exempt
  rate            Float
  effectiveFrom   DateTime @default(now())
  effectiveTo     DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  taxCategory     TaxCategory @relation(fields: [taxCategoryId], references: [id], onDelete: Cascade)

  @@index([taxCategoryId])
  @@index([isActive])
  @@map("tax_rates")
}

model TaxFiling {
  id              String   @id @default(cuid())
  storeId         String
  filingPeriod    String   // "2024-01", "2024-Q1"
  filingType      String   @default("VAT") // VAT, WHT, INCOME_TAX, TURNOVER_TAX
  totalSales      Float    @default(0)
  totalTax        Float    @default(0)
  totalWht        Float    @default(0)
  status          String   @default("DRAFT") // DRAFT, FILED, APPROVED, PAID, LATE
  filingDate      DateTime?
  dueDate         DateTime?
  etimsReference  String?
  notes           String?
  filedBy         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([filingType])
  @@index([status])
  @@index([filingPeriod])
  @@map("tax_filings")
}

// ============================================================
// STORE TRANSFERS (Inter-Store)
// ============================================================

model StoreTransfer {
  id              String   @id @default(cuid())
  transferNumber  String   @unique
  fromStoreId     String
  toStoreId       String
  status          String   @default("PENDING") // PENDING, IN_TRANSIT, RECEIVED, CANCELLED, PARTIAL
  requestedBy     String?  // User ID
  approvedBy      String?  // User ID
  receivedBy      String?  // User ID
  shippedAt       DateTime?
  receivedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fromStore       Store              @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore         Store              @relation("TransferTo", fields: [toStoreId], references: [id])
  items           StoreTransferItem[]

  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([status])
  @@map("store_transfers")
}

model StoreTransferItem {
  id              String   @id @default(cuid())
  transferId      String
  productId       String
  quantity        Float
  receivedQty     Float    @default(0)
  unitType        String   @default("PIECE")
  notes           String?

  transfer        StoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([productId])
  @@map("store_transfer_items")
}

// ============================================================
// EXPENSE BUDGETS & APPROVALS
// ============================================================

model ExpenseBudget {
  id              String   @id @default(cuid())
  storeId         String
  category        String   // RENT, SALARIES, UTILITIES, TRANSPORT, MAINTENANCE, MARKETING, OTHER
  period          String   // "2024-01", "2024-Q1", "2024"
  budgetAmount    Float
  spentAmount     Float    @default(0)
  remainingAmount Float    @default(0)
  status          String   @default("ACTIVE") // ACTIVE, CLOSED, EXCEEDED
  approvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  approvals       ExpenseApproval[]

  @@index([storeId])
  @@index([category])
  @@index([period])
  @@map("expense_budgets")
}

model ExpenseApproval {
  id              String   @id @default(cuid())
  expenseId       String?  // Link to Expense
  budgetId        String?  // Link to ExpenseBudget
  approvalType    String   @default("EXPENSE") // EXPENSE, BUDGET, TRANSFER, WRITE_OFF
  amount          Float
  requestedBy     String   // User ID
  approvedBy      String?  // User ID
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  approvalLevel   Int      @default(1) // 1 = first level, 2 = second level
  notes           String?
  requestedAt     DateTime @default(now())
  approvedAt      DateTime?

  budget          ExpenseBudget? @relation(fields: [budgetId], references: [id])

  @@index([expenseId])
  @@index([status])
  @@index([requestedBy])
  @@map("expense_approvals")
}

// ============================================================
// CUSTOMER INTERACTIONS (CRM)
// ============================================================

model CustomerInteraction {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  interactionType String   @default("NOTE") // NOTE, CALL, EMAIL, VISIT, WHATSAPP, COMPLAINT, FEEDBACK
  subject         String?
  content         String
  followUpDate    DateTime?
  status          String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo      String?  // User ID
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([interactionType])
  @@index([status])
  @@index([createdAt])
  @@map("customer_interactions")
}

// ============================================================
// MESSAGING MODULE (SMS & WhatsApp)
// ============================================================

model Message {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String?
  channel         String   @default("WHATSAPP") // SMS, WHATSAPP, BOTH
  messageType     String   @default("CUSTOM") // DEBT_REMINDER, PAYMENT_CONFIRMATION, BALANCE_UPDATE, PROMOTION, CUSTOM
  subject         String?
  content         String
  status          String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED, READ
  waLink          String?
  errorMessage     String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([channel])
  @@index([messageType])
  @@index([status])
  @@index([createdAt])
  @@map("messages")
}
