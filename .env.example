# ============================================================================
# MBUMAH HARDWARE POS & ERP — Self-Hosting Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your deployment.
# NEVER commit your .env file to version control.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker-compose.prod.yml up -d
# ============================================================================

# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL credentials for the Docker Compose stack.
# These are used by both the postgres container AND the app container.
# IMPORTANT: Change the password from the default for production!
POSTGRES_USER=mbumah
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=mbumah_pos

# The app container uses these internal URLs to connect to postgres.
# They are constructed automatically in docker-compose.prod.yml using the
# POSTGRES_USER/PASSWORD/DB values above. You do NOT need to set these
# manually unless you are using an external database.
# DATABASE_URL=postgresql://mbumah:password@postgres:5432/mbumah_pos?sslmode=disable&connect_timeout=15
# DIRECT_URL=postgresql://mbumah:password@postgres:5432/mbumah_pos?sslmode=disable&connect_timeout=30

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Full URL of your deployed app (no trailing slash).
# Use https:// if SSL is configured, http:// if testing without SSL.
NEXTAUTH_URL=https://your-server.com
# JWT secret for custom token auth — generate with: openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32

# ─── APPLICATION ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-server.com
NEXT_PUBLIC_CURRENCY=KES

# ─── NGINX / SSL ─────────────────────────────────────────────────────────────
# Ports to expose on the host. Defaults to 80 (HTTP) and 443 (HTTPS).
# Change if you already have services on those ports.
# HTTP_PORT=80
# HTTPS_PORT=443

# ─── M-PESA DARAJA API (Safaricom) ─────────────────────────────────────────
# Register at https://developer.safaricom.co.ke/ to get credentials.
# Required for M-Pesa STK Push payments.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
# Set to "production" when going live with real M-Pesa transactions.
# Keep as "sandbox" for testing with Safaricom's test environment.
MPESA_ENVIRONMENT=sandbox
# Callback URL for M-Pesa STK Push results.
# Must be publicly accessible (e.g., https://your-server.com/api/payments/mpesa/callback)
MPESA_CALLBACK_URL=https://your-server.com/api/payments/mpesa/callback

# ─── NOTIFICATIONS (Optional) ───────────────────────────────────────────────
# Resend for email notifications (https://resend.com/)
RESEND_API_KEY=

# Twilio for SMS notifications (https://www.twilio.com/)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── REDIS (Optional — for production caching & sessions) ───────────────────
# If you have a Redis instance running, uncomment and set the URL.
# Can be added to docker-compose.prod.yml as a service if needed.
# REDIS_URL=redis://redis:6379

# ─── DIAGNOSTICS (DO NOT USE IN PRODUCTION) ─────────────────────────────────
# Exposes full error details in 500 responses for debugging.
# ONLY enable temporarily while diagnosing production issues.
# EXPOSE_ERRORS=true
