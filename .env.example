# MBUMAH HARDWARE POS & ERP - Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your .env file to version control.

# DATABASE - Local Development (SQLite)
DATABASE_URL="file:./db/custom.db"
DIRECT_URL="file:./db/custom.db"

# DATABASE - Production / Vercel + Neon (PostgreSQL)
# Step 1: Create a free Neon database at https://console.neon.tech
# Step 2: Copy the connection string from the Dashboard
# Step 3: Uncomment and fill in the values below
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-HOSTNAME.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-HOSTNAME.us-east-1.aws.neon.tech/neondb?sslmode=require"

# AUTHENTICATION - NextAuth.js (required for production)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
# Full URL of your deployed app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Legacy JWT secret (if using JWT auth directly)
# Generate: openssl rand -base64 32
JWT_SECRET="change-this-in-production"

# APP CONFIGURATION
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY="KES"

# M-PESA DARAJA API (Safaricom)
# Register at https://developer.safaricom.co.ke/ to get credentials
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE="174379"
MPESA_ENVIRONMENT="sandbox"
# Callback URL for M-Pesa STK Push results (must be publicly accessible)
MPESA_CALLBACK_URL="https://your-app.vercel.app/api/mpesa/callback"

# NOTIFICATIONS (Optional)
# Resend for email notifications
RESEND_API_KEY=""

# Twilio for SMS notifications
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
