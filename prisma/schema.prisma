// ─────────────────────────────────────────────────────────────────────────────
// PAYROLL & HUMAN RESOURCES (Phase 1 — ERP Enhancement)
// ─────────────────────────────────────────────────────────────────────────────
//
// Design notes:
//
//   • Multi-tenancy: Every store-scoped model carries a non-nullable `storeId`
//     and is registered in `STORE_SCOPED_MODELS` in src/lib/db.ts so the Prisma
//     Client Extension automatically AND-injects `storeId` into every query.
//     This enforces zero-trust tenant isolation at the ORM layer — developers
//     cannot "forget" to scope a payroll query by store.
//
//   • LeaveType is the ONLY model here WITHOUT a storeId. Leave types are
//     organisation-wide policy (Annual, Sick, Maternity, Compassionate, etc.)
//     defined once and referenced by every store. EmployeeLeaveBalance,
//     LeaveRequest, etc. resolve via employee.storeId.
//
//   • Monetary fields now use Decimal @db.Decimal(12,2) (banker's rounding)
//     across the entire schema — Product.pricePerUnit, SalesTransaction.total,
//     PayrollDetail.netPay, etc. This Phase 2 migration ensures KRA eTIMS
//     compliance and eliminates IEEE-754 float rounding errors. Payroll
//     fields (basicSalary, grossPay, paye, nssf, nhif, etc.) follow the
//     same convention.
//
//   • PAYSLIP immutability: PayrollDetail is append-only (a payslip, once
//     generated, must never be silently edited — corrections are made via
//     adjusting entries in the next payroll run). PayrollDetail is registered
//     in IMMUTABLE_MODELS in src/lib/db.ts; sanctioned mutations (e.g. voiding
//     a payslip) use withImmutabilityBypass().
//
//   • Status enums are stored as String (not Prisma enum) for SQLite/dev
//     compatibility and to allow adding new statuses without a migration.
//     The allowed values are documented inline and enforced at the API layer.
//
//   • PAYE/NSSF/NHDF: Kenyan statutory deductions are calculated in
//     src/lib/payroll-helpers.ts (Phase 2). The schema stores the FINAL
//     computed amounts; the breakdown is preserved in the `deductionsBreakdown`
//     JSON column for auditability and payslip rendering.
// ─────────────────────────────────────────────────────────────────────────────

/// A staff member employed at a store. An Employee MAY be linked to a User
/// account (so they can log in and view their own payslips / request leave),
/// but does not HAVE to be — casual labourers and contractors without system
/// access still need payroll records.
model Employee {
  id      String @id @default(cuid())
  storeId String

  // Optional link to a system User account. When set, the employee can log in
  // and access the self-service portal (view payslips, request leave, clock in).
  // CASCADE on User delete: if the user account is removed, the employee record
  // is preserved (set to null) so historical payroll is never orphaned.
  userId String? @unique

  // Identity
  firstName  String
  lastName   String
  email      String? // Unique per store (not globally) — two stores
  // could legitimately have employees with the
  // same personal email.
  phone      String?
  nationalId String? // Kenyan National ID — required for KRA PAYE
  kraPin     String? // KRA PIN — required for PAYE returns
  nssfNumber String? // National Social Security Fund
  nhifNumber String? // National Hospital Insurance Fund (now SHIF)
  photoUrl   String?

  // Employment
  jobTitle        String? // e.g. "Senior Cashier", "Store Supervisor"
  role            String    @default("STAFF") // STAFF, SUPERVISOR, MANAGER, CASHIER, ACCOUNTANT
  employmentType  String    @default("PERMANENT") // PERMANENT, CONTRACT, CASUAL, PROBATION, INTERN
  hireDate        DateTime
  terminationDate DateTime? // null = active; set when employment ends
  status          String    @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED, ON_LEAVE

  // Compensation (monthly figures in KES)
  basicSalary        Decimal  @default(0) @db.Decimal(12, 2) // Gross basic before allowances/deductions
  hourlyRate         Decimal? @db.Decimal(12, 2) // For casual/overtime calculation
  houseAllowance     Decimal  @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal  @default(0) @db.Decimal(12, 2)
  medicalAllowance   Decimal  @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal  @default(0) @db.Decimal(12, 2)

  // Statutory deduction config (computed at payroll time; stored here as the
  // employee's current configuration). Actual per-run amounts live in
  // PayrollDetail.deductionsBreakdown.
  payeExempt Boolean @default(false) // KRA PAYE exemption (e.g. disabled persons)
  nssfExempt Boolean @default(false)
  nhifExempt Boolean @default(false)

  // Bank details for salary disbursement (NEVER store raw account numbers in
  // logs — mask in UI). Encrypted at rest by Neon TLS; application-layer
  // encryption can be layered on later if required.
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankBranchCode    String?
  bankSwift         String? // For international wires (rare in Kenya)

  // Emergency contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Metadata
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store             Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user              User?                  @relation(fields: [userId], references: [id])
  payrollDetails    PayrollDetail[]
  leaveBalances     EmployeeLeaveBalance[]
  leaveRequests     LeaveRequest[]
  attendanceRecords AttendanceRecord[]

  @@unique([storeId, email])
  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@index([hireDate])
  @@index([employmentType])
  @@index([storeId, status])
  @@map("employees")
}

/// A payroll cycle (e.g. "January 2026", "Week 5 2026"). A store creates one
/// PayrollPeriod per cycle; a PayrollRun is then generated against it.
model PayrollPeriod {
  id         String    @id @default(cuid())
  storeId    String
  name       String // e.g. "January 2026" or "2026-W05"
  startDate  DateTime
  endDate    DateTime
  payDate    DateTime? // Scheduled disbursement date
  status     String    @default("DRAFT") // DRAFT, PROCESSING, PAID, VOIDED
  periodType String    @default("MONTHLY") // MONTHLY, WEEKLY, BI_WEEKLY

  // Aggregate totals (computed when the run is processed). Stored on the
  // period for fast dashboard rendering without joining PayrollDetail.
  totalGross      Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @default(0) @db.Decimal(12, 2)
  totalNet        Decimal @default(0) @db.Decimal(12, 2)
  employeeCount   Int     @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  runs  PayrollRun[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([storeId, status])
  @@map("payroll_periods")
}

/// A single execution of payroll for a PayrollPeriod. A period may have
/// multiple runs (e.g. initial run + a supplementary run for late hires),
/// though typically just one. Each run produces a PayrollDetail per employee.
model PayrollRun {
  id              String @id @default(cuid())
  payrollPeriodId String
  storeId         String // Denormalised from PayrollPeriod for tenant-scoping

  runType     String    @default("REGULAR") // REGULAR, SUPPLEMENTARY, OFF_CYCLE, BONUS
  status      String    @default("DRAFT") // DRAFT, PROCESSING, COMPLETED, PAID, VOIDED, FAILED
  initiatedBy String? // User ID of the manager who initiated the run
  processedAt DateTime?
  paidAt      DateTime?

  // Aggregate totals for THIS run (sum of PayrollDetail rows)
  totalGross      Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @default(0) @db.Decimal(12, 2)
  totalNet        Decimal @default(0) @db.Decimal(12, 2)
  employeeCount   Int     @default(0)

  // Failure context (if status = FAILED)
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollPeriod PayrollPeriod   @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  store         Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  details       PayrollDetail[]

  @@index([payrollPeriodId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([storeId, status])
  @@map("payroll_runs")
}

/// An individual payslip line within a PayrollRun. One row per employee per
/// run. This is the IMMUTABLE financial record — once a run is COMPLETED, the
/// PayrollDetail rows must never be edited (corrections go in the next run).
model PayrollDetail {
  id           String @id @default(cuid())
  payrollRunId String
  employeeId   String
  storeId      String // Denormalised for tenant-scoping

  // Earnings breakdown (KES)
  basicSalary        Decimal @default(0) @db.Decimal(12, 2)
  houseAllowance     Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  medicalAllowance   Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)
  overtimePay        Decimal @default(0) @db.Decimal(12, 2)
  grossPay           Decimal @default(0) @db.Decimal(12, 2) // Sum of all earnings

  // Statutory deductions (KES) — computed per Kenyan law in payroll-helpers.ts
  paye        Decimal @default(0) @db.Decimal(12, 2) // Pay As You Earn income tax
  nssf        Decimal @default(0) @db.Decimal(12, 2) // National Social Security Fund
  nhif        Decimal @default(0) @db.Decimal(12, 2) // National Hospital Insurance Fund / SHIF
  housingLevy Decimal @default(0) @db.Decimal(12, 2) // Affordable Housing Levy (1.5%)

  // Other deductions
  payeArrears     Decimal @default(0) @db.Decimal(12, 2)
  loanDeduction   Decimal @default(0) @db.Decimal(12, 2) // Salary advance / staff loan recovery
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @default(0) @db.Decimal(12, 2) // Sum of all deductions

  netPay Decimal @default(0) @db.Decimal(12, 2) // grossPay - totalDeductions

  // Working stats for the period (used in calculation + payslip display)
  daysWorked    Int     @default(0)
  daysPresent   Int     @default(0)
  daysAbsent    Int     @default(0)
  daysOnLeave   Int     @default(0)
  overtimeHours Decimal @default(0) @db.Decimal(8, 2)

  // JSON breakdown for audit / payslip rendering. Stored as String for SQLite
  // compat; PostgreSQL could use Json type. Contains the full calc trace:
  //   { "payeBands": [...], "nssfTier": "...", "nhifTier": "...", ... }
  deductionsBreakdown String?

  // Payment status & reference
  paymentStatus String    @default("PENDING") // PENDING, PAID, FAILED, HELD
  paymentRef    String? // Bank transfer reference / M-Pesa B2B ref
  paymentDate   DateTime?
  payslipPdfUrl String? // Generated PDF path (S3/Vercel Blob)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([storeId])
  @@index([paymentStatus])
  @@index([storeId, paymentStatus])
  @@map("payroll_details")
}

/// Organisation-wide leave policy types. NOT store-scoped (a leave type is a
/// policy concept, not tenant data). Specific entitlements per employee live
/// in EmployeeLeaveBalance.
model LeaveType {
  id                  String   @id @default(cuid())
  name                String   @unique // Annual, Sick, Maternity, Paternity, Compassionate, Study, Sabbatical
  code                String   @unique // ANNUAL, SICK, MATERNITY, etc.
  description         String?
  defaultDaysPerYear  Decimal  @default(0) @db.Decimal(8, 2) // 0 = unlimited (e.g. Compassionate)
  isPaid              Boolean  @default(true)
  isStatutory         Boolean  @default(false) // True for leave mandated by Kenyan law
  carryForwardAllowed Boolean  @default(true)
  maxCarryForwardDays Decimal  @default(0) @db.Decimal(8, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  balances EmployeeLeaveBalance[]
  requests LeaveRequest[]

  @@index([isActive])
  @@index([isStatutory])
  @@map("leave_types")
}

/// Per-employee leave entitlement tracker. One row per (employee, leaveType).
/// Updated when a LeaveRequest is approved (usedDays += requested) and on the
/// start of a new leave year (availableDays resets, carryForward applied).
model EmployeeLeaveBalance {
  id          String @id @default(cuid())
  employeeId  String
  leaveTypeId String

  // The leave "year" this balance applies to (an employee may have multiple
  // rows per leaveType across years). For most orgs this aligns with the
  // calendar year, but some use a hire-anniversary cycle.
  leaveYear Int // e.g. 2026

  allocatedDays    Decimal @default(0) @db.Decimal(8, 2) // Days granted for this year
  usedDays         Decimal @default(0) @db.Decimal(8, 2) // Days already taken / approved
  pendingDays      Decimal @default(0) @db.Decimal(8, 2) // Days in PENDING leave requests
  carryForwardDays Decimal @default(0) @db.Decimal(8, 2) // Brought forward from prior year
  encashedDays     Decimal @default(0) @db.Decimal(8, 2) // Days paid out in lieu

  // available = allocated + carryForward - used - pending
  // (Computed at read time to avoid drift; not stored.)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, leaveYear])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([leaveYear])
  @@map("employee_leave_balances")
}

/// A leave request submitted by an employee. Approval workflow:
///   PENDING → APPROVED | REJECTED | CANCELLED
/// On APPROVED: EmployeeLeaveBalance.usedDays += (endDate - startDate + 1) days
/// On REJECTED/CANCELLED: EmployeeLeaveBalance.pendingDays -= same
model LeaveRequest {
  id          String @id @default(cuid())
  employeeId  String
  leaveTypeId String
  storeId     String // Denormalised from Employee for tenant-scoping

  startDate   DateTime
  endDate     DateTime
  returnDate  DateTime? // Expected return (defaults to endDate + 1 day)
  workingDays Decimal   @default(0) @db.Decimal(8, 2) // Computed: count of working days in range
  halfDay     Boolean   @default(false)

  status          String  @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED, TAKEN
  reason          String? // Employee's stated reason
  rejectionReason String? // Manager's reason if rejected
  attachmentUrl   String? // e.g. medical certificate for sick leave

  // Approval chain
  approvedBy String? // User ID of approver
  approvedAt DateTime?

  // Emergency contact during leave (optional)
  emergencyContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([storeId])
  @@index([status])
  @@index([startDate])
  @@index([storeId, status])
  @@index([employeeId, status])
  @@map("leave_requests")
}

/// Daily attendance / time-tracking record. One row per employee per day.
/// Supports both simple clock-in/out and shift-based attendance.
model AttendanceRecord {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String // Denormalised for tenant-scoping
  // NOTE: stored as DateTime (not @db.Date) for SQLite/dev compatibility.
  // The application layer enforces date-only semantics (midnight UTC).
  // On PostgreSQL a future migration can switch this to @db.Date.
  date       DateTime // The calendar day (no time component)

  // Clock times (nullable for manual entries / absent days)
  checkIn    DateTime?
  checkOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  breakHours Decimal   @default(0) @db.Decimal(8, 2) // Total break time in hours

  // Computed totals
  workingHours  Decimal @default(0) @db.Decimal(8, 2) // (checkOut - checkIn) - breakHours
  overtimeHours Decimal @default(0) @db.Decimal(8, 2) // Hours beyond the standard shift
  expectedHours Decimal @default(8) @db.Decimal(8, 2) // Standard shift length

  status            String @default("PRESENT") // PRESENT, ABSENT, LATE, HALF_DAY, LEAVE, HOLIDAY, WEEKEND, REMOTE
  lateMinutes       Int    @default(0) // Minutes late past shift start
  earlyLeaveMinutes Int    @default(0)

  // Source / verification
  source   String  @default("MANUAL") // MANUAL, BIOMETRIC, MOBILE, RFID
  location String? // GPS / IP at clock-in (for remote verification)
  verified Boolean @default(false) // Verified by a supervisor?

  notes      String?
  approvedBy String? // Supervisor who approved manual entries
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([storeId])
  @@index([date])
  @@index([status])
  @@index([storeId, date])
  @@index([employeeId, date])
  @@map("attendance_records")
}

// ════════════════════════════════════════════════════════════════════════════
// v2.0.0 — eTIMS / KRA INTEGRATION CONTEXT
// ════════════════════════════════════════════════════════════════════════════
//
// These models support Kenya Revenue Authority's electronic Tax Invoice
// Management System (eTIMS). Every sales invoice must be submitted to KRA and
// a CU/QR code returned. The flow:
//   1. Sale completes → InvoiceForKRA row created (PENDING)
//   2. KraApiService.submitInvoice() calls the KRA endpoint
//   3. KraSubmission row records the API call (request/response/latency)
//   4. InvoiceForKRA.kraSubmissionId + submissionStatus updated
//
// Enum-like fields use String (not Prisma enum) to stay consistent with the
// rest of the schema and compatible with the SQLite→PostgreSQL provider
// switch. Values are documented inline.

/// KRA business profile — org/store-level credentials & registration details.
/// One per store (a store may have its own KRA PIN). Credentials are stored
/// AES-encrypted at rest (see src/lib/crypto-helpers.ts).
model KraBusinessProfile {
  id                   String    @id @default(cuid())
  storeId              String
  businessPin          String    @unique // KRA PIN, e.g. "P051234567X"
  businessName         String
  registrationDate     DateTime
  kraUsername          String // eTIMS portal username
  kraPasswordEncrypted String // AES-encrypted (NEVER plaintext)
  // Sandbox vs production — KRA provides a test environment.
  environment          String    @default("sandbox") // sandbox, production
  isActive             Boolean   @default(true)
  // Cached OAuth token (eTIMS uses bearer tokens with expiry).
  authToken            String?
  authTokenExpiresAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([businessPin])
  @@index([isActive])
  @@map("kra_business_profiles")
}

/// A sales invoice mapped to KRA's eTIMS format. One per SalesTransaction.
/// Links back to the originating transaction; tracks submission lifecycle.
model InvoiceForKRA {
  id               String    @id @default(cuid())
  storeId          String
  transactionId    String    @unique // 1:1 with SalesTransaction
  // KRA invoice number format: <PIN>-<YYYYMMDD>-<seq>. Generated per KRA spec.
  kraInvoiceNumber String    @unique
  // JSON blob: item-level tax breakdown (VAT 16%, exempt, zero-rated), HS
  // codes, discounts, totals. Flexible schema for evolving KRA requirements.
  kraTaxBreakdown  String // JSON string (SQLite-compatible; Json on PG)
  // PENDING → SUBMITTED → ACCEPTED | REJECTED | FAILED
  submissionStatus String    @default("PENDING")
  // KRA returns a CU (Communication Unit) reference after acceptance.
  kraSubmissionId  String?
  cuPin            String? // CU PIN returned by KRA (for QR code)
  qrCode           String? // Base64 QR code data
  submittedAt      DateTime?
  acceptedAt       DateTime?
  // Retry tracking for transient failures.
  retryCount       Int       @default(0)
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  submissions KraSubmission[]

  @@index([storeId])
  @@index([submissionStatus])
  @@index([kraInvoiceNumber])
  @@index([submittedAt])
  @@map("invoices_for_kra")
}

/// Audit log of every KRA API call (submit, status query, business info).
/// One InvoiceForKRA may have many KraSubmission rows (retries, status polls).
model KraSubmission {
  id                 String    @id @default(cuid())
  storeId            String
  invoiceForKraId    String
  // KRA reference number returned after submission.
  kraReferenceNumber String?
  // PENDING, SUBMITTED, ACCEPTED, REJECTED, FAILED
  status             String    @default("PENDING")
  // Full API response JSON for debugging / dispute resolution.
  responseJson       String? // JSON string
  httpStatus         Int?
  latencyMs          Int?
  errorMessage       String?
  submittedAt        DateTime  @default(now())
  processedAt        DateTime?

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invoiceForKra InvoiceForKRA @relation(fields: [invoiceForKraId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([invoiceForKraId])
  @@index([status])
  @@index([submittedAt])
  @@map("kra_submissions")
}

// ════════════════════════════════════════════════════════════════════════════
// v2.0.0 — DEBT MANAGEMENT CONTEXT (reminders)
// ════════════════════════════════════════════════════════════════════════════
//
// DebtLedger (existing) already has agingBucket + lastReminderAt fields.
// This model tracks each individual reminder sent, for audit + escalation
// rules (frequency increases with aging bucket).

/// A single debt-reminder event. One DebtLedger may have many reminders.
model DebtReminder {
  id                String    @id @default(cuid())
  storeId           String
  customerId        String
  debtLedgerId      String
  // EMAIL, SMS, WHATSAPP, IN_APP
  reminderType      String
  // PENDING, SENT, FAILED, DELIVERED
  status            String    @default("PENDING")
  // Template / message content used (for audit).
  message           String
  // External provider message ID (Twilio/Resend) for delivery tracking.
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?

  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id])
  debtLedger DebtLedger @relation(fields: [debtLedgerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([debtLedgerId])
  @@index([reminderType])
  @@index([status])
  @@index([sentAt])
  @@map("debt_reminders")
}

// ════════════════════════════════════════════════════════════════════════════
// v2.0.0 — MESSAGING CONTEXT (internal staff chat + notifications)
// ════════════════════════════════════════════════════════════════════════════
//
// NOTE: The existing `Message` model (above) handles OUTBOUND customer
// notifications (WhatsApp/SMS/Email blasts). This new Conversation +
// ConversationMessage pair handles INTERNAL staff chat (real-time, threaded).
// They are deliberately separate to avoid conflating two distinct domains.

/// A conversation thread — internal staff chat or customer-support chat.
model Conversation {
  id                 String    @id @default(cuid())
  storeId            String
  // INTERNAL (staff-to-staff), CUSTOMER_SUPPORT (staff-to-customer)
  type               String    @default("INTERNAL")
  title              String? // Optional human-readable title
  // JSON array of participant user IDs (and customer ID for support chats).
  // Stored as String for SQLite compat; parsed in the application layer.
  participantIds     String    @default("[]")
  lastMessageAt      DateTime?
  lastMessagePreview String? // First ~100 chars of latest message (for list UI)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store    Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([storeId])
  @@index([type])
  @@index([lastMessageAt])
  @@map("conversations")
}

/// A single message in a conversation. Separate from the outbound `Message`
/// model — this is for threaded internal/customer-support chat.
model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String // User ID of the sender
  content        String
  // TEXT, IMAGE, FILE, SYSTEM (join/leave notifications)
  messageType    String   @default("TEXT")
  // JSON: { userId: "2026-06-26T12:00:00Z" } per-recipient read timestamps.
  readStatus     String   @default("{}")
  // Optional attachment URL (for IMAGE/FILE types).
  attachmentUrl  String?
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([sentAt])
  @@map("conversation_messages")
}

/// Per-user / per-customer notification channel preferences. Drives which
/// channels (EMAIL, SMS, IN_APP) receive which alert types.
model NotificationPreference {
  id         String   @id @default(cuid())
  userId     String? // For staff users
  customerId String? // For customers
  // EMAIL, SMS, IN_APP, WHATSAPP
  channel    String
  // Alert categories this preference applies to (e.g. LOW_STOCK, OVERDUE_RENTAL,
  // DEBT_REMINDER, NEW_SALE). Use "ALL" for a blanket preference.
  alertType  String   @default("ALL")
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([channel])
  @@index([alertType])
  @@map("notification_preferences")
}

// ════════════════════════════════════════════════════════════════════════════
// v2.0.0 — INVENTORY CONTEXT ENHANCEMENTS
// ════════════════════════════════════════════════════════════════════════════
//
// Optional physical-tracking models for warehouses that need finer-grained
// inventory control. All are optional (a product need not have variants,
// serials, batches, or bin locations).

/// A product variant — e.g. "Cement 50kg" vs "Cement 25kg" under one parent.
/// Enables size/colour/style differentiation without duplicating the parent.
model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  storeId         String
  // Variant descriptor, e.g. "50kg", "Red", "Type-A"
  name            String
  sku             String   @unique
  barcode         String?
  // Variant-specific pricing/stock (overrides parent if set).
  pricePerUnit    Decimal? @db.Decimal(12, 2)
  costPrice       Decimal? @db.Decimal(12, 2)
  quantityInStock Decimal  @default(0) @db.Decimal(10, 3)
  reorderLevel    Decimal  @default(10) @db.Decimal(10, 3)
  isActive        Boolean  @default(true)
  // Variant attributes as JSON (e.g. {"size":"50kg","color":"grey"}).
  attributes      String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([storeId])
  @@index([sku])
  @@index([isActive])
  @@map("product_variants")
}

/// Bin location — physical shelf/aisle/row where stock is stored. Enables
/// pick-path optimization and multi-location tracking within one store.
model BinLocation {
  id           String   @id @default(cuid())
  productId    String
  storeId      String
  // E.g. "Aisle A, Shelf 3, Bin 12"
  locationCode String
  aisle        String?
  shelf        String?
  bin          String?
  // Quantity stored at this specific bin (sum across bins = Product.quantityInStock).
  quantity     Decimal  @default(0) @db.Decimal(10, 3)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([storeId])
  @@index([locationCode])
  @@index([isActive])
  @@map("bin_locations")
}

/// Serial number — tracks individual units of a product (for warranty,
/// returns, high-value items). One product may have many serials.
model SerialNumber {
  id                  String    @id @default(cuid())
  productId           String
  storeId             String
  serial              String    @unique
  // IN_STOCK, SOLD, RESERVED, RETURNED, DEFECTIVE
  status              String    @default("IN_STOCK")
  // Link to the sale that sold this unit (for warranty tracking).
  soldInTransactionId String?
  warrantyExpiry      DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([storeId])
  @@index([serial])
  @@index([status])
  @@map("serial_numbers")
}

/// Batch — tracks groups of items received together (for expiry tracking,
/// recall management, supplier traceability). Common for construction
/// chemicals, paints, adhesives.
model Batch {
  id                String    @id @default(cuid())
  productId         String
  storeId           String
  batchNumber       String
  // Quantity remaining in this batch (decremented on sale).
  quantity          Decimal   @default(0) @db.Decimal(10, 3)
  // Supplier who provided this batch (for recall traceability).
  supplierId        String?
  receivedDate      DateTime  @default(now())
  manufacturingDate DateTime?
  expiryDate        DateTime?
  // ACTIVE, EXPIRED, RECALLED, DEPLETED
  status            String    @default("ACTIVE")
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([storeId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@index([status])
  @@map("batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2 — Production-grade schema completion + Decimal money migration.
//
// The 14 models below were referenced by API routes + UI tabs but were never
// declared in schema.prisma — causing `db.<model>` to be `undefined` at
// runtime (500 errors) and TS2339 at compile time. They are added here using
// the same conventions as the rest of the schema:
//   • String @id @default(cuid()) for cross-DB compatibility
//   • storeId on all store-scoped models (multi-tenancy)
//   • String for enum-like fields (SQLite compat — no Prisma enums)
//   • Decimal for monetary fields (arbitrary precision; works on SQLite
//     NUMERIC and PostgreSQL DECIMAL). NOTE: no @db.Decimal annotation so
//     the schema compiles on BOTH providers.
//   • @@map for clean DB table names
//   • Comprehensive @@index for query performance
// ─────────────────────────────────────────────────────────────────────────────

// ── BANKING (3 models) ───────────────────────────────────────────────────────
// Tracks real-world bank / M-Pesa / petty-cash accounts per store, their
// transactions, and statement reconciliations.

model BankAccount {
  id             String   @id @default(cuid())
  storeId        String
  bankName       String
  accountName    String
  accountNumber  String
  branch         String?
  swiftCode      String?
  currency       String   @default("KES")
  accountType    String   @default("CHECKING") // CHECKING, SAVINGS, MPESA, PETTY_CASH
  openingBalance Decimal  @default(0)
  currentBalance Decimal  @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions    BankTransaction[]
  reconciliations BankReconciliation[]

  @@index([storeId])
  @@index([accountType])
  @@index([isActive])
  @@index([bankName])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String    @id @default(cuid())
  bankAccountId   String
  transactionType String // DEPOSIT, WITHDRAWAL, TRANSFER_IN, TRANSFER_OUT, FEE, INTEREST, MPESA_IN, MPESA_OUT
  amount          Decimal // Positive for inflow, negative for outflow
  balanceAfter    Decimal // Running balance after this transaction
  reference       String?
  description     String?
  transactionDate DateTime  @default(now())
  isReconciled    Boolean   @default(false)
  reconciledAt    DateTime?
  createdAt       DateTime  @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([transactionType])
  @@index([transactionDate])
  @@index([isReconciled])
  @@map("bank_transactions")
}

model BankReconciliation {
  id               String   @id @default(cuid())
  bankAccountId    String
  statementDate    DateTime
  statementBalance Decimal
  bookBalance      Decimal
  difference       Decimal  @default(0)
  status           String   @default("DRAFT") // DRAFT, MATCHED, DISCREPANCY, RESOLVED
  notes            String?
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([statementDate])
  @@index([status])
  @@map("bank_reconciliations")
}

// ── LOYALTY (3 models + CustomerLoyalty) ─────────────────────────────────────
// Tiered loyalty program: customers earn points per purchase, tiers unlock
// discounts. Campaigns provide time-limited bonus-point promotions.

model LoyaltyTier {
  id               String   @id @default(cuid())
  storeId          String
  name             String
  minPoints        Int      @default(0)
  maxPoints        Int?
  discountPercent  Decimal  @default(0)
  pointsMultiplier Decimal  @default(1) // E.g. 1.5 = earn 50% extra points
  benefits         String? // JSON string of benefit descriptors
  color            String   @default("#6B7280")
  icon             String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerTiers       CustomerLoyalty[] // back-relation: customers currently at this tier
  loyaltyCampaigns    LoyaltyCampaign[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([storeId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("loyalty_tiers")
}

model LoyaltyCampaign {
  id                 String    @id @default(cuid())
  storeId            String
  name               String
  campaignType       String // BONUS_MULTIPLIER, BONUS_FIXED, DOUBLE_POINTS, TARGET_REWARD
  description        String?
  bonusPoints        Int       @default(0)
  multiplier         Decimal   @default(1)
  startDate          DateTime  @default(now())
  endDate            DateTime?
  targetTierId       String?
  status             String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED, CANCELLED
  totalPointsAwarded Int       @default(0)
  totalParticipants  Int       @default(0)
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store      Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  targetTier LoyaltyTier? @relation(fields: [targetTierId], references: [id])

  @@index([storeId])
  @@index([campaignType])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("loyalty_campaigns")
}

model LoyaltyTransaction {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  tierId          String?
  points          Int // Positive = earned, negative = redeemed
  transactionType String // EARN, REDEEM, ADJUST, BONUS, EXPIRE
  reference       String?
  referenceId     String? // FK to originating SalesTransaction etc. (not enforced)
  referenceType   String? // SALE, REDEMPTION, MANUAL_ADJUST, CAMPAIGN
  description     String?
  createdBy       String?
  createdAt       DateTime @default(now())

  store    Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier     LoyaltyTier? @relation(fields: [tierId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([transactionType])
  @@index([referenceId])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model CustomerLoyalty {
  id             String    @id @default(cuid())
  customerId     String    @unique
  tierId         String?
  pointsBalance  Int       @default(0)
  lifetimePoints Int       @default(0)
  totalRedeemed  Int       @default(0)
  tierAchievedAt DateTime?
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier     LoyaltyTier? @relation(fields: [tierId], references: [id])

  @@index([customerId])
  @@index([tierId])
  @@map("customer_loyalty")
}

// ── CUSTOMER INTERACTIONS (CRM) ──────────────────────────────────────────────
// Logs every interaction with a customer (call, visit, complaint, follow-up)
// for CRM visibility. Linked to Customer for a 360-degree view.

model CustomerInteraction {
  id              String    @id @default(cuid())
  storeId         String
  customerId      String
  interactionType String // CALL, EMAIL, VISIT, MEETING, COMPLAINT, FOLLOW_UP, NOTE
  subject         String?
  content         String
  followUpDate    DateTime?
  status          String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo      String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([interactionType])
  @@index([status])
  @@index([priority])
  @@index([followUpDate])
  @@map("customer_interactions")
}

// ── TAX (2 models) ───────────────────────────────────────────────────────────
// Tax categories (rate + eTIMS code) and tax filings (period returns).

model TaxCategory {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  rate          Decimal   @default(0) // Percentage, e.g. 16 for 16% VAT
  description   String?
  etimsCode     String? // KRA eTIMS tax-type code
  isActive      Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  taxRates TaxRate[]

  @@index([storeId])
  @@index([isActive])
  @@index([etimsCode])
  @@map("tax_categories")
}

// TaxRate is a child of TaxCategory, allowing a single category (e.g. "VAT")
// to have multiple rate bands over time or by product class.
model TaxRate {
  id            String    @id @default(cuid())
  taxCategoryId String
  name          String
  rate          Decimal   @default(0)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  taxCategory TaxCategory @relation(fields: [taxCategoryId], references: [id], onDelete: Cascade)

  @@index([taxCategoryId])
  @@index([isActive])
  @@map("tax_rates")
}

model TaxFiling {
  id             String    @id @default(cuid())
  storeId        String
  filingPeriod   String // e.g. "2026-06" (YYYY-MM)
  filingType     String // VAT, WHT, PAYE, CORPORATE_INCOME, TURNOVER
  totalSales     Decimal   @default(0)
  totalTax       Decimal   @default(0)
  totalWht       Decimal   @default(0) // Withholding tax
  status         String    @default("DRAFT") // DRAFT, FILED, ACCEPTED, REJECTED, AMENDED
  filingDate     DateTime?
  dueDate        DateTime?
  etimsReference String?
  notes          String?
  filedBy        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([filingPeriod])
  @@index([filingType])
  @@index([status])
  @@index([dueDate])
  @@map("tax_filings")
}

// ── SUBCATEGORY (Product sub-classification) ─────────────────────────────────
model SubCategory {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([categoryId])
  @@index([isActive])
  @@map("subcategories")
}

// ── STORE TRANSFERS (2 models) ───────────────────────────────────────────────
// Inter-branch stock transfers: a StoreTransfer has many StoreTransferItems;
// each item moves a quantity of a Product from one store to another. Status
// flows PENDING → IN_TRANSIT → PARTIAL → COMPLETED | CANCELLED.

model StoreTransfer {
  id             String    @id @default(cuid())
  transferNumber String    @unique
  fromStoreId    String
  toStoreId      String
  status         String    @default("PENDING") // PENDING, IN_TRANSIT, PARTIAL, COMPLETED, CANCELLED
  requestedBy    String?
  approvedBy     String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fromStore Store               @relation("TransferFromStore", fields: [fromStoreId], references: [id])
  toStore   Store               @relation("TransferToStore", fields: [toStoreId], references: [id])
  items     StoreTransferItem[]

  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([status])
  @@index([transferNumber])
  @@map("store_transfers")
}

model StoreTransferItem {
  id          String   @id @default(cuid())
  transferId  String
  productId   String
  quantity    Decimal  @default(0)
  unitType    String   @default("PIECE")
  receivedQty Decimal  @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  transfer StoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([productId])
  @@map("store_transfer_items")
}

// ── INVENTORY (per-store stock ledger) ───────────────────────────────────────
// A separate per-store stock record (productId + storeId + quantityInStock)
// used by store transfers and inventory reconciliation. Distinct from
// Product.quantityInStock (which is the aggregate default-store quantity).

model Inventory {
  id              String    @id @default(cuid())
  productId       String
  storeId         String
  quantityInStock Decimal   @default(0)
  reorderLevel    Decimal   @default(10)
  lastStockCount  DateTime?
  status          String    @default("ACTIVE") // ACTIVE, DISCONTINUED, OUT_OF_STOCK
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
  @@index([productId])
  @@index([storeId])
  @@index([status])
  @@map("inventories")
}

// ── NOTIFICATION (user-facing alerts) ────────────────────────────────────────
// In-app notification centre entries. Distinct from Message (which is
// outbound messaging) and ConversationMessage (staff chat).

model Notification {
  id          String    @id @default(cuid())
  storeId     String?
  userId      String? // null = broadcast to all users in store
  title       String
  message     String
  type        String    @default("INFO") // INFO, SUCCESS, WARNING, ERROR, SALE, STOCK, SYSTEM
  category    String? // SALES, INVENTORY, PAYMENTS, SECURITY, etc.
  priority    String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  isRead      Boolean   @default(false)
  readAt      DateTime?
  actionUrl   String? // Deep link to act on the notification
  actionLabel String?
  metadata    String? // JSON string for extra context
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  store Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@map("notifications")
}
