  eventType String // RATE_LIMITED, CSRF_FAILED, BRUTE_FORCE, INVALID_INPUT, SUSPICIOUS_ACTIVITY, ACCOUNT_LOCKED, SESSION_HIJACK_ATTEMPT, UNAUTHORIZED_ACCESS
  severity  String   @default("WARN") // DEBUG, INFO, WARN, ERROR, CRITICAL
