# ============================================================================
# MBUMAH HARDWARE POS — Docker Ignore
# Reduces build context size and prevents sensitive files from entering images
# ============================================================================

# Dependencies (installed fresh inside the container)
node_modules
.pnp
.pnp.js

# Next.js build output (built inside the container)
.next
out

# Build artifacts
dist
build

# Environment files (secrets must NOT be baked into images)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database files (SQLite local dev)
db/*.db
db/*.db-journal

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
dev.log
server.log

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Docker (prevent recursive builds)
docker-compose*.yml
Dockerfile
.dockerignore

# Testing
coverage
.nyc_output

# Misc
*.pem
*.key
