# ============================================================================
# MBUMAH HARDWARE POS & ERP - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your .env file to version control.
# ============================================================================

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL="file:./db/custom.db"
# Production / Vercel + Supabase (PostgreSQL):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
# Direct connection (for Prisma migrations — bypasses PgBouncer):
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# NextAuth.js (required for production)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
# Full URL of your deployed app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Legacy JWT secret (if using JWT auth directly)
# Generate: openssl rand -base64 32
JWT_SECRET="change-this-in-production"

# ─── APP CONFIGURATION ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY="KES"     # Kenyan Shillings

# ─── M-PESA DARAJA API (Safaricom) ─────────────────────────────────────────
# Register at https://developer.safaricom.co.ke/ to get credentials
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE="174379"
MPESA_ENVIRONMENT="sandbox"    # "sandbox" for development, "production" for live
# Callback URL for M-Pesa STK Push results (must be publicly accessible)
MPESA_CALLBACK_URL="https://your-app.vercel.app/api/mpesa/callback"

# ─── NOTIFICATIONS (Optional) ───────────────────────────────────────────────
# Resend for email notifications
RESEND_API_KEY=""

# Twilio for SMS notifications
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── REDIS (Optional — for production caching & sessions) ───────────────────
# REDIS_URL="redis://localhost:6379"

# ─── SUPABASE (if using Supabase Auth/Storage in addition to database) ──────
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
