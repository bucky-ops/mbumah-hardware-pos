// MBUMAH HARDWARE POS & ERP - Prisma Schema
// Multi-tenant via storeId discriminator. PostgreSQL for prod, SQLite for dev.
//
// The committed provider is "postgresql" (for Vercel production).
// For local dev with SQLite, `scripts/setup-prisma-provider.sh` runs in
// `postinstall` and detects the DATABASE_URL scheme:
//   • file:./...        → switches to sqlite      (local dev)
//   • postgresql://...  → stays postgresql         (Vercel / Neon / Supabase)
//   • unset             → stays postgresql         (Vercel install phase)
//
// The `vercel-build` script is `SKIP_ENV_VALIDATION=1 prisma generate && next build`
// — no provider manipulation at build time. The correct Prisma client is
// generated during `postinstall` (which runs the setup script for local dev).
//
// Notes:
//   - IDs use cuid() for cross-DB compat
//   - Monetary fields use Decimal @db.Decimal(12,2) (banker's rounding)
//   - Quantity fields use Decimal @db.Decimal(10,3); rates @db.Decimal(5,2)
//   - Hours/days fields use Decimal @db.Decimal(8,2) for payroll precision
//   - JSON metadata stored as String; switch to Json type on PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Committed as "postgresql" for Vercel. Auto-switched to "sqlite" by
  // scripts/setup-prisma-provider.sh during postinstall when DATABASE_URL
  // starts with "file:" (local dev). Do not edit manually.
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── TENANCY & ORGANIZATION
model Organization {
  id        String   @id @default(cuid())
  name      String
  taxPin    String? // KRA PIN for Kenyan businesses
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores   Store[]
  users    User[]
  accounts Account[]

  @@map("organizations")
}

model Store {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  location       String?
  address        String?
  phone          String?
  email          String?
  taxPin         String? // Store-level KRA PIN
  status         String   @default("ACTIVE") // ACTIVE, CLOSED, RENOVATING
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users            User[]
  products         Product[]
  categories       ProductCategory[]
  customerCredits  CustomerCredit[]
  customers        Customer[]
  transactions     SalesTransaction[]
  payments         Payment[]
  debtLedgers      DebtLedger[]
  debtPayments     DebtPayment[]
  rentals          EquipmentRental[]
  stockMovements   StockMovement[]
  warehouseStocks  WarehouseStock[]
  journalEntries   JournalEntry[]
  systemLogs       SystemLog[]
  cashDrawerLogs   CashDrawerLog[]
  receipts         Receipt[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  expenses         Expense[]
  shifts           Shift[]
  giftCards        GiftCard[]
  vouchers         Voucher[]
  voucherCampaigns VoucherCampaign[]
  messages         Message[]
  invoices         Invoice[]
  deliveryNotes    DeliveryNote[]

  // ── Payroll & HR (Phase 1 — ERP enhancement) ──
  // NOTE: LeaveType and EmployeeLeaveBalance are NOT directly related to Store:
  //   • LeaveType is organisation-wide policy (not tenant data)
  //   • EmployeeLeaveBalance resolves via Employee.storeId
  // Only the store-scoped payroll models have a direct Store relation here.
  employees            Employee[]
  payrollPeriods       PayrollPeriod[]
  payrollRuns          PayrollRun[]
  payrollDetails       PayrollDetail[]
  leaveRequests        LeaveRequest[]
  attendanceRecords    AttendanceRecord[]
  // ── v2.0.0 module relations ────────────────────────────────────────────
  kraBusinessProfiles  KraBusinessProfile[]
  invoicesForKRA       InvoiceForKRA[]
  kraSubmissions       KraSubmission[]
  debtReminders        DebtReminder[]
  conversations        Conversation[]
  productVariants      ProductVariant[]
  binLocations         BinLocation[]
  serialNumbers        SerialNumber[]
  batches              Batch[]
  // ── Phase 2 production-grade module relations ──────────────────────────
  bankAccounts         BankAccount[]
  loyaltyTiers         LoyaltyTier[]
  loyaltyCampaigns     LoyaltyCampaign[]
  loyaltyTransactions  LoyaltyTransaction[]
  customerInteractions CustomerInteraction[]
  taxCategories        TaxCategory[]
  taxFilings           TaxFiling[]
  storeTransfersFrom   StoreTransfer[]       @relation("TransferFromStore")
  storeTransfersTo     StoreTransfer[]       @relation("TransferToStore")
  inventories          Inventory[]
  notifications        Notification[]

  @@index([organizationId])
  @@map("stores")
}

// AUTHENTICATION & RBAC

model User {
  id                  String    @id @default(cuid())
  organizationId      String
  storeId             String?
  email               String    @unique
  name                String
  passwordHash        String
  role                String    @default("CASHIER") // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, CASHIER, ACCOUNTANT
  phone               String?
  avatarUrl           String?
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  lockedUntil         DateTime? // Account locked until this time
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store           Store?             @relation(fields: [storeId], references: [id])
  sessions        Session[]
  systemLogs      SystemLog[]
  transactions    SalesTransaction[]
  cashDrawerLogs  CashDrawerLog[]
  shifts          Shift[]
  issuedGiftCards GiftCard[]         @relation("IssuedByUser")

  // Employee profile (optional — an employee may exist without a user account,
  // e.g. casual labourers; a user may exist without an employee profile, e.g.
  // an org-level SUPER_ADMIN who isn't on any store payroll).
  employee Employee?

  // ── v2.0.0 messaging relations ─────────────────────────────────────────
  sentMessages            ConversationMessage[]
  notificationPreferences NotificationPreference[]

  @@index([organizationId])
  @@index([storeId])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt DateTime @default(now()) // Track session activity
  isSuspicious Boolean  @default(false) // Flag suspicious sessions
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RolePermission {
  id        String   @id @default(cuid())
  role      String // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, CASHIER, ACCOUNTANT
  resource  String // products, transactions, customers, financials, rentals, admin, reports
  action    String // create, read, update, delete, approve, refund, export
  createdAt DateTime @default(now())

  @@unique([role, resource, action])
  @@map("role_permissions")
}

// PRODUCT & INVENTORY

model ProductCategory {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products      Product[]
  subcategories SubCategory[]

  @@index([storeId])
  @@map("product_categories")
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  categoryId        String?
  subcategoryId     String? // Phase 2: finer-grained classification
  sku               String   @unique
  barcode           String?  @unique
  name              String
  description       String?
  unitType          String   @default("PIECE") // PIECE, KILOGRAM, METER, LITER, BAG, BOX, SET
  quantityInStock   Decimal  @default(0) @db.Decimal(10, 3)
  reorderLevel      Decimal  @default(10) @db.Decimal(10, 3)
  pricePerUnit      Decimal  @db.Decimal(12, 2) // Selling price
  costPrice         Decimal  @db.Decimal(12, 2) // Purchase/cost price
  taxRate           Decimal  @default(16) @db.Decimal(5, 2) // Kenya VAT 16%
  isRental          Boolean  @default(false)
  isBundle          Boolean  @default(false)
  isActive          Boolean  @default(true)
  imageUrl          String?
  // ── v2.0.0 inventory enhancements ──────────────────────────────────────
  // minimumStockLevel is the absolute floor below which the product is
  // considered out-of-stock for alerting (distinct from reorderLevel, which
  // is the threshold that triggers a reorder). maximumStockLevel caps the
  // shelf capacity for replenishment planning (null = unlimited).
  minimumStockLevel Int      @default(0)
  maximumStockLevel Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  subcategory        SubCategory?        @relation(fields: [subcategoryId], references: [id])
  bundleItems        ProductBundle[]     @relation("BundleParent")
  parentBundles      ProductBundle[]     @relation("BundleChild")
  saleItems          SaleItem[]
  stockMovements     StockMovement[]
  warehouseStocks    WarehouseStock[]
  rentals            EquipmentRental[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems       InvoiceItem[]
  deliveryNoteItems  DeliveryNoteItem[]
  // ── v2.0.0 inventory relations ─────────────────────────────────────────
  variants           ProductVariant[]
  binLocations       BinLocation[]
  serialNumbers      SerialNumber[]
  batches            Batch[]
  // ── Phase 2 production-grade relations ──────────────────────────────────
  storeTransferItems StoreTransferItem[]
  inventories        Inventory[]

  @@index([storeId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([isActive])
  // Composite multi-tenant performance index (ISO 27001: scoped storeId + time range)
  @@index([storeId, createdAt])
  @@map("products")
}

model ProductBundle {
  id               String  @id @default(cuid())
  parentProductId  String // The bundle product
  childProductId   String // The constituent product
  quantityRequired Decimal @default(1) @db.Decimal(10, 3) // How many of child in one bundle

  parentProduct Product @relation("BundleParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  childProduct  Product @relation("BundleChild", fields: [childProductId], references: [id], onDelete: Cascade)

  @@unique([parentProductId, childProductId])
  @@index([parentProductId])
  @@map("product_bundles")
}

model WarehouseStock {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  warehouse String   @default("MAIN") // MAIN, BACKUP, RECEIVING
  quantity  Decimal  @default(0) @db.Decimal(10, 3)
  updatedAt DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, warehouse])
  @@index([storeId])
  @@map("warehouse_stocks")
}

model StockMovement {
  id           String   @id @default(cuid())
  storeId      String
  productId    String
  movementType String // PURCHASE, SALE, ADJUSTMENT, TRANSFER, RETURN, RENTAL_OUT, RENTAL_RETURN
  quantity     Decimal  @db.Decimal(10, 3) // Positive for in, negative for out
  referenceId  String? // Transaction ID, PO ID, etc.
  notes        String?
  performedBy  String? // User ID
  createdAt    DateTime @default(now())

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
  @@map("stock_movements")
}

// CUSTOMERS & CRM

model Customer {
  id                 String   @id @default(cuid())
  storeId            String
  name               String
  phone              String?
  email              String?
  address            String?
  idNumber           String? // Kenyan National ID
  currentDebtBalance Decimal  @default(0) @db.Decimal(12, 2)
  debtLimit          Decimal  @default(50000) @db.Decimal(12, 2) // KES default limit
  loyaltyPoints      Int      @default(0)
  preferredChannel   String   @default("SMS") // SMS, EMAIL, WHATSAPP, PRINT
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedgers  DebtLedger[]
  transactions SalesTransaction[]
  rentals      EquipmentRental[]
  giftCards    GiftCard[]         @relation("IssuedToCustomer")

  customerCredits         CustomerCredit[]
  // ── v2.0.0 debt-management + messaging relations ───────────────────────
  debtReminders           DebtReminder[]
  notificationPreferences NotificationPreference[]
  // ── Phase 2 production-grade relations ──────────────────────────────────
  loyalty                 CustomerLoyalty?
  loyaltyTransactions     LoyaltyTransaction[]
  customerInteractions    CustomerInteraction[]

  @@index([storeId])
  @@index([phone])
  @@index([name])
  @@map("customers")
}

model CustomerCredit {
  id          String    @id @default(cuid())
  storeId     String
  customerId  String
  amount      Decimal   @db.Decimal(12, 2)
  creditType  String    @default("CREDIT") // CREDIT, DEBIT, ADJUSTMENT, REFUND
  balance     Decimal   @default(0) @db.Decimal(12, 2) // Running balance after this entry
  reference   String? // e.g. INV-001, PAY-2024-03
  description String?
  status      String    @default("ACTIVE") // ACTIVE, VOIDED
  voidedAt    DateTime?
  voidedBy    String? // User ID who voided
  voidReason  String?
  createdBy   String? // User ID
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([creditType])
  @@index([status])
  @@index([createdAt])
  @@map("customer_credits")
}

// SALES & TRANSACTIONS

model SalesTransaction {
  id              String    @id @default(cuid())
  storeId         String
  receiptNumber   String    @unique
  customerId      String?
  cashierId       String
  subtotal        Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal   @db.Decimal(12, 2)
  paymentMethod   String // CASH, MPESA, DEBT, SPLIT
  paymentStatus   String    @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED, PARTIAL
  transactionType String    @default("SALE") // SALE, REFUND, VOID
  notes           String?
  isOffline       Boolean   @default(false)
  syncedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store               Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer            Customer?            @relation(fields: [customerId], references: [id])
  cashier             User                 @relation(fields: [cashierId], references: [id])
  items               SaleItem[]
  payments            Payment[]
  debtLedgers         DebtLedger[]
  receipt             Receipt?
  giftCardRedemptions GiftCardRedemption[]
  voucherRedemptions  VoucherRedemption[]
  deliveryNote        DeliveryNote?
  // ── v2.0.0 eTIMS relation ──────────────────────────────────────────────
  kraInvoice          InvoiceForKRA?

  @@index([storeId])
  @@index([cashierId])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([receiptNumber])
  @@index([paymentMethod])
  @@index([createdAt])
  // Composite multi-tenant performance index (ISO 27001: scoped storeId + time range)
  @@index([storeId, createdAt])
  @@map("sales_transactions")
}

model SaleItem {
  id              String  @id @default(cuid())
  transactionId   String
  productId       String
  productName     String // Snapshot at time of sale
  quantity        Decimal @db.Decimal(10, 3)
  unitType        String
  pricePerUnit    Decimal @db.Decimal(12, 2)
  costPrice       Decimal @db.Decimal(12, 2) // Snapshot for profit calculation
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  taxRate         Decimal @default(16) @db.Decimal(5, 2)
  lineTotal       Decimal @db.Decimal(12, 2)
  isRentalItem    Boolean @default(false)

  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("sale_items")
}

// PAYMENTS

model Payment {
  id            String   @id @default(cuid())
  storeId       String
  transactionId String
  paymentMethod String // CASH, MPESA, DEBT
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("KES")
  status        String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED
  reference     String? // M-Pesa CheckoutRequestID, receipt number, etc.
  metadata      String? // JSON string for additional payment details
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([transactionId])
  @@index([paymentMethod])
  @@index([status])
  @@map("payments")
}

model MpesaTransaction {
  id                 String   @id @default(cuid())
  storeId            String
  checkoutRequestId  String?
  merchantRequestId  String?
  mpesaReceiptNumber String?
  phoneNumber        String?
  amount             Decimal  @db.Decimal(12, 2)
  status             String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  resultCode         String?
  resultDesc         String?
  callbackReceived   Boolean  @default(false)
  transactionId      String? // Link to SalesTransaction
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([storeId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("mpesa_transactions")
}

// DEBT / CREDIT MANAGEMENT

model DebtLedger {
  id             String    @id @default(cuid())
  storeId        String
  customerId     String
  transactionId  String?
  amountOwed     Decimal   @db.Decimal(12, 2)
  amountPaid     Decimal   @default(0) @db.Decimal(12, 2)
  balance        Decimal   @db.Decimal(12, 2) // amountOwed - amountPaid
  dueDate        DateTime
  status         String    @default("OUTSTANDING") // OUTSTANDING, PARTIAL, SETTLED, OVERDUE, WRITTEN_OFF
  agingBucket    String    @default("CURRENT") // CURRENT, DAYS_30, DAYS_60, DAYS_90_PLUS
  lastReminderAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  transaction  SalesTransaction? @relation(fields: [transactionId], references: [id])
  debtPayments DebtPayment[]
  // ── v2.0.0 debt-management relation ────────────────────────────────────
  reminders    DebtReminder[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([agingBucket])
  @@index([dueDate])
  @@map("debt_ledgers")
}

model DebtPayment {
  id            String   @id @default(cuid())
  storeId       String
  debtLedgerId  String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String // CASH, MPESA
  reference     String?
  receivedBy    String? // User ID
  createdAt     DateTime @default(now())

  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedger DebtLedger @relation(fields: [debtLedgerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([debtLedgerId])
  @@map("debt_payments")
}

// EQUIPMENT RENTAL

model EquipmentRental {
  id                 String    @id @default(cuid())
  storeId            String
  productId          String
  customerId         String
  status             String    @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE, DAMAGED, LOST
  rentalStartDate    DateTime  @default(now())
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  securityDeposit    Decimal   @db.Decimal(12, 2)
  ratePerDay         Decimal   @db.Decimal(12, 2)
  ratePerWeek        Decimal?  @db.Decimal(12, 2)
  ratePerMonth       Decimal?  @db.Decimal(12, 2)
  totalRentalCharge  Decimal   @default(0) @db.Decimal(12, 2)
  lateFeeAccumulated Decimal   @default(0) @db.Decimal(12, 2)
  damageAssessment   String? // NONE, MINOR, MODERATE, SEVERE
  damageCharge       Decimal   @default(0) @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([expectedReturnDate])
  @@map("equipment_rentals")
}

// FINANCIAL ACCOUNTING - DOUBLE-ENTRY BOOKKEEPING

model Account {
  id             String   @id @default(cuid())
  organizationId String
  code           String // Account code e.g. 1000, 2000, 3000
  name           String
  type           String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType        String? // CURRENT_ASSET, FIXED_ASSET, CURRENT_LIABILITY, etc.
  normalBalance  String   @default("DEBIT") // DEBIT, CREDIT
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalEntryLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([type])
  @@map("accounts")
}

model JournalEntry {
  id            String    @id @default(cuid())
  storeId       String
  entryNumber   String    @unique
  entryDate     DateTime  @default(now())
  description   String
  referenceType String? // SALE, PAYMENT, REFUND, RENTAL, ADJUSTMENT
  referenceId   String? // Transaction ID, Payment ID, etc.
  totalDebit    Decimal   @db.Decimal(12, 2)
  totalCredit   Decimal   @db.Decimal(12, 2)
  isPosted      Boolean   @default(false)
  isVoided      Boolean   @default(false)
  postedAt      DateTime?
  voidedAt      DateTime?
  voidedBy      String?
  createdBy     String? // User ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  lines JournalEntryLine[]

  @@index([storeId])
  @@index([entryDate])
  @@index([referenceType])
  @@index([isPosted])
  @@index([createdAt])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  description    String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// CASH DRAWER MANAGEMENT

model CashDrawerLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  action    String // OPEN, CLOSE, CASH_IN, CASH_OUT, SALE, REFUND
  amount    Decimal  @db.Decimal(12, 2)
  balance   Decimal  @db.Decimal(12, 2) // Running balance
  notes     String?
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@map("cash_drawer_logs")
}

// RECEIPTS

model Receipt {
  id            String    @id @default(cuid())
  storeId       String
  transactionId String    @unique
  receiptNumber String    @unique
  receiptType   String    @default("DIGITAL") // DIGITAL, PRINTED, EMAIL, SMS, WHATSAPP
  sentTo        String? // Phone or email
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

