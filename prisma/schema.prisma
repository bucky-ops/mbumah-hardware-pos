// MBUMAH HARDWARE POS & ERP - Prisma Schema
// Multi-tenant via storeId discriminator. PostgreSQL for prod, SQLite for dev.
//
// The committed provider is "postgresql" (for Vercel production).
// For local dev with SQLite, `scripts/setup-prisma-provider.sh` runs in
// `postinstall` and detects the DATABASE_URL scheme:
//   • file:./...        → switches to sqlite      (local dev)
//   • postgresql://...  → stays postgresql         (Vercel / Neon / Supabase)
//
// The `build` script is just `next build` — no provider manipulation at
// build time. The correct Prisma client is generated during `postinstall`.
//
// Notes:
//   - IDs use cuid() for cross-DB compat
//   - Monetary fields are Float; migrate to Decimal for production
//   - JSON metadata stored as String; switch to Json type on PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Committed as "postgresql" for Vercel. Auto-switched to "sqlite" by
  // scripts/setup-prisma-provider.sh during postinstall when DATABASE_URL
  // starts with "file:" (local dev). Do not edit manually.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── TENANCY & ORGANIZATION
model Organization {
  id          String   @id @default(cuid())
  name        String
  taxPin      String?  // KRA PIN for Kenyan businesses
  status      String   @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stores      Store[]
  users       User[]
  accounts    Account[]

  @@map("organizations")
}

model Store {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  location        String?
  address         String?
  phone           String?
  email           String?
  taxPin          String?  // Store-level KRA PIN
  status          String   @default("ACTIVE") // ACTIVE, CLOSED, RENOVATING
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  products        Product[]
  categories      ProductCategory[]
  customerCredits CustomerCredit[]
  customers       Customer[]
  transactions    SalesTransaction[]
  payments        Payment[]
  debtLedgers     DebtLedger[]
  debtPayments    DebtPayment[]
  rentals         EquipmentRental[]
  stockMovements  StockMovement[]
  warehouseStocks WarehouseStock[]
  journalEntries  JournalEntry[]
  systemLogs      SystemLog[]
  cashDrawerLogs  CashDrawerLog[]
  receipts        Receipt[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  expenses        Expense[]
  shifts          Shift[]
  giftCards       GiftCard[]
  vouchers        Voucher[]
  voucherCampaigns VoucherCampaign[]
  messages        Message[]
  invoices        Invoice[]
  deliveryNotes   DeliveryNote[]

  @@index([organizationId])
  @@map("stores")
}

// AUTHENTICATION & RBAC

model User {
  id              String   @id @default(cuid())
  organizationId  String
  storeId         String?
  email           String   @unique
  name            String
  passwordHash    String
  role            String   @default("CASHIER") // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, CASHIER, ACCOUNTANT
  phone           String?
  avatarUrl       String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  lockedUntil      DateTime?  // Account locked until this time
  failedLoginAttempts Int     @default(0)
  lastFailedLoginAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store           Store?       @relation(fields: [storeId], references: [id])
  sessions           Session[]
  systemLogs         SystemLog[]
  transactions       SalesTransaction[]
  cashDrawerLogs     CashDrawerLog[]
  shifts             Shift[]
  issuedGiftCards    GiftCard[]         @relation("IssuedByUser")

  @@index([organizationId])
  @@index([storeId])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt    DateTime  @default(now()) // Track session activity
  isSuspicious    Boolean   @default(false) // Flag suspicious sessions
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         String   // SUPER_ADMIN, STORE_OWNER, BRANCH_MANAGER, CASHIER, ACCOUNTANT
  resource     String   // products, transactions, customers, financials, rentals, admin, reports
  action       String   // create, read, update, delete, approve, refund, export
  createdAt    DateTime @default(now())

  @@unique([role, resource, action])
  @@map("role_permissions")
}

// PRODUCT & INVENTORY

model ProductCategory {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  description     String?
  icon            String?
  color           String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products        Product[]

  @@index([storeId])
  @@map("product_categories")
}

model Product {
  id                String   @id @default(cuid())
  storeId           String
  categoryId        String?
  sku               String   @unique
  barcode           String?  @unique
  name              String
  description       String?
  unitType          String   @default("PIECE") // PIECE, KILOGRAM, METER, LITER, BAG, BOX, SET
  quantityInStock   Float    @default(0)
  reorderLevel      Float    @default(10)
  pricePerUnit      Float    // Selling price
  costPrice         Float    // Purchase/cost price
  taxRate           Float    @default(16) // Kenya VAT 16%
  isRental          Boolean  @default(false)
  isBundle          Boolean  @default(false)
  isActive          Boolean  @default(true)
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category          ProductCategory? @relation(fields: [categoryId], references: [id])
  bundleItems       ProductBundle[]  @relation("BundleParent")
  parentBundles     ProductBundle[]  @relation("BundleChild")
  saleItems         SaleItem[]
  stockMovements    StockMovement[]
  warehouseStocks   WarehouseStock[]
  rentals           EquipmentRental[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems       InvoiceItem[]
  deliveryNoteItems  DeliveryNoteItem[]

  @@index([storeId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@index([categoryId])
  @@index([isActive])
  // Composite multi-tenant performance index (ISO 27001: scoped storeId + time range)
  @@index([storeId, createdAt])
  @@map("products")
}

model ProductBundle {
  id                String   @id @default(cuid())
  parentProductId   String   // The bundle product
  childProductId    String   // The constituent product
  quantityRequired  Float    @default(1) // How many of child in one bundle

  parentProduct     Product  @relation("BundleParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  childProduct      Product  @relation("BundleChild", fields: [childProductId], references: [id], onDelete: Cascade)

  @@unique([parentProductId, childProductId])
  @@index([parentProductId])
  @@map("product_bundles")
}

model WarehouseStock {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  warehouse   String   @default("MAIN") // MAIN, BACKUP, RECEIVING
  quantity    Float    @default(0)
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, warehouse])
  @@index([storeId])
  @@map("warehouse_stocks")
}

model StockMovement {
  id              String   @id @default(cuid())
  storeId         String
  productId       String
  movementType    String   // PURCHASE, SALE, ADJUSTMENT, TRANSFER, RETURN, RENTAL_OUT, RENTAL_RETURN
  quantity        Float    // Positive for in, negative for out
  referenceId     String?  // Transaction ID, PO ID, etc.
  notes           String?
  performedBy     String?  // User ID
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
  @@map("stock_movements")
}

// CUSTOMERS & CRM

model Customer {
  id                  String   @id @default(cuid())
  storeId             String
  name                String
  phone               String?
  email               String?
  address             String?
  idNumber            String?  // Kenyan National ID
  currentDebtBalance  Float    @default(0)
  debtLimit           Float    @default(50000) // KES default limit
  loyaltyPoints       Int      @default(0)
  preferredChannel    String   @default("SMS") // SMS, EMAIL, WHATSAPP, PRINT
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store               Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedgers         DebtLedger[]
  transactions        SalesTransaction[]
  rentals             EquipmentRental[]
  giftCards           GiftCard[]         @relation("IssuedToCustomer")

  customerCredits     CustomerCredit[]

  @@index([storeId])
  @@index([phone])
  @@index([name])
  @@map("customers")
}

model CustomerCredit {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  amount          Float
  creditType      String   @default("CREDIT") // CREDIT, DEBIT, ADJUSTMENT, REFUND
  balance         Float    @default(0)         // Running balance after this entry
  reference       String?                      // e.g. INV-001, PAY-2024-03
  description     String?
  status          String   @default("ACTIVE")  // ACTIVE, VOIDED
  voidedAt        DateTime?
  voidedBy        String?                      // User ID who voided
  voidReason      String?
  createdBy       String?                      // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([creditType])
  @@index([status])
  @@index([createdAt])
  @@map("customer_credits")
}

// SALES & TRANSACTIONS

model SalesTransaction {
  id              String   @id @default(cuid())
  storeId         String
  receiptNumber   String   @unique
  customerId      String?
  cashierId       String
  subtotal        Float
  taxAmount       Float
  discountAmount  Float    @default(0)
  totalAmount     Float
  paymentMethod   String   // CASH, MPESA, DEBT, SPLIT
  paymentStatus   String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED, PARTIAL
  transactionType String   @default("SALE") // SALE, REFUND, VOID
  notes           String?
  isOffline       Boolean  @default(false)
  syncedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer?   @relation(fields: [customerId], references: [id])
  cashier         User        @relation(fields: [cashierId], references: [id])
  items           SaleItem[]
  payments             Payment[]
  debtLedgers          DebtLedger[]
  receipt              Receipt?
  giftCardRedemptions  GiftCardRedemption[]
  voucherRedemptions   VoucherRedemption[]
  deliveryNote         DeliveryNote?

  @@index([storeId])
  @@index([cashierId])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([receiptNumber])
  @@index([paymentMethod])
  @@index([createdAt])
  // Composite multi-tenant performance index (ISO 27001: scoped storeId + time range)
  @@index([storeId, createdAt])
  @@map("sales_transactions")
}

model SaleItem {
  id              String   @id @default(cuid())
  transactionId   String
  productId       String
  productName     String   // Snapshot at time of sale
  quantity        Float
  unitType        String
  pricePerUnit    Float
  costPrice       Float    // Snapshot for profit calculation
  discountPercent Float    @default(0)
  taxRate         Float    @default(16)
  lineTotal       Float
  isRentalItem    Boolean  @default(false)

  transaction     SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("sale_items")
}

// PAYMENTS

model Payment {
  id              String   @id @default(cuid())
  storeId         String
  transactionId   String
  paymentMethod   String   // CASH, MPESA, DEBT
  amount          Float
  currency        String   @default("KES")
  status          String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED
  reference       String?  // M-Pesa CheckoutRequestID, receipt number, etc.
  metadata        String?  // JSON string for additional payment details
  processedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([transactionId])
  @@index([paymentMethod])
  @@index([status])
  @@map("payments")
}

model MpesaTransaction {
  id                    String   @id @default(cuid())
  storeId               String
  checkoutRequestId     String?
  merchantRequestId     String?
  mpesaReceiptNumber    String?
  phoneNumber           String?
  amount                Float
  status                String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  resultCode            String?
  resultDesc            String?
  callbackReceived      Boolean  @default(false)
  transactionId         String?  // Link to SalesTransaction
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([storeId])
  @@index([checkoutRequestId])
  @@index([status])
  @@map("mpesa_transactions")
}

// DEBT / CREDIT MANAGEMENT

model DebtLedger {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String
  transactionId   String?
  amountOwed      Float
  amountPaid      Float    @default(0)
  balance         Float    // amountOwed - amountPaid
  dueDate         DateTime
  status          String   @default("OUTSTANDING") // OUTSTANDING, PARTIAL, SETTLED, OVERDUE, WRITTEN_OFF
  agingBucket     String   @default("CURRENT") // CURRENT, DAYS_30, DAYS_60, DAYS_90_PLUS
  lastReminderAt  DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer          @relation(fields: [customerId], references: [id])
  transaction     SalesTransaction? @relation(fields: [transactionId], references: [id])
  debtPayments    DebtPayment[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([agingBucket])
  @@index([dueDate])
  @@map("debt_ledgers")
}

model DebtPayment {
  id              String   @id @default(cuid())
  storeId         String
  debtLedgerId    String
  amount          Float
  paymentMethod   String   // CASH, MPESA
  reference       String?
  receivedBy      String?  // User ID
  createdAt       DateTime @default(now())

  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  debtLedger      DebtLedger  @relation(fields: [debtLedgerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([debtLedgerId])
  @@map("debt_payments")
}

// EQUIPMENT RENTAL

model EquipmentRental {
  id                  String   @id @default(cuid())
  storeId             String
  productId           String
  customerId          String
  status              String   @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE, DAMAGED, LOST
  rentalStartDate     DateTime @default(now())
  expectedReturnDate  DateTime
  actualReturnDate    DateTime?
  securityDeposit     Float
  ratePerDay          Float
  ratePerWeek         Float?
  ratePerMonth        Float?
  totalRentalCharge   Float    @default(0)
  lateFeeAccumulated  Float    @default(0)
  damageAssessment    String?  // NONE, MINOR, MODERATE, SEVERE
  damageCharge        Float    @default(0)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])
  customer            Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([expectedReturnDate])
  @@map("equipment_rentals")
}

// FINANCIAL ACCOUNTING - DOUBLE-ENTRY BOOKKEEPING

model Account {
  id              String   @id @default(cuid())
  organizationId  String
  code            String   // Account code e.g. 1000, 2000, 3000
  name            String
  type            String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType         String?  // CURRENT_ASSET, FIXED_ASSET, CURRENT_LIABILITY, etc.
  normalBalance   String   @default("DEBIT") // DEBIT, CREDIT
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalEntryLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([type])
  @@map("accounts")
}

model JournalEntry {
  id              String   @id @default(cuid())
  storeId         String
  entryNumber     String   @unique
  entryDate       DateTime @default(now())
  description     String
  referenceType   String?  // SALE, PAYMENT, REFUND, RENTAL, ADJUSTMENT
  referenceId     String?  // Transaction ID, Payment ID, etc.
  totalDebit      Float
  totalCredit     Float
  isPosted        Boolean  @default(false)
  isVoided        Boolean  @default(false)
  postedAt        DateTime?
  voidedAt        DateTime?
  voidedBy        String?
  createdBy       String?  // User ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  lines           JournalEntryLine[]

  @@index([storeId])
  @@index([entryDate])
  @@index([referenceType])
  @@index([isPosted])
  @@index([createdAt])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String   @id @default(cuid())
  journalEntryId  String
  accountId       String
  debit           Float    @default(0)
  credit          Float    @default(0)
  description     String?
  createdAt       DateTime @default(now())

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// CASH DRAWER MANAGEMENT

model CashDrawerLog {
  id              String   @id @default(cuid())
  storeId         String
  userId          String
  action          String   // OPEN, CLOSE, CASH_IN, CASH_OUT, SALE, REFUND
  amount          Float
  balance         Float    // Running balance
  notes           String?
  createdAt       DateTime @default(now())

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
  @@map("cash_drawer_logs")
}

// RECEIPTS

model Receipt {
  id              String   @id @default(cuid())
  storeId         String
  transactionId   String   @unique
  receiptNumber   String   @unique
  receiptType     String   @default("DIGITAL") // DIGITAL, PRINTED, EMAIL, SMS, WHATSAPP
  sentTo          String?  // Phone or email
  sentAt          DateTime?
  createdAt       DateTime @default(now())

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction  @relation(fields: [transactionId], references: [id])

  @@index([storeId])
  @@index([transactionId])
  @@map("receipts")
}

// SUPPLIER & PURCHASE ORDERS

model Supplier {
  id            String   @id @default(cuid())
  storeId       String
  name          String
  email         String?
  phone         String?
  address       String?
  city          String?
  contactPerson String?
  taxPin        String?
  paymentTerms  String   @default("NET_30") // NET_15, NET_30, NET_60, IMMEDIATE
  rating        Int      @default(3) // 1-5 stars
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([storeId])
  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  storeId         String
  poNumber        String   @unique
  supplierId      String
  status          String   @default("DRAFT") // DRAFT, SENT, CONFIRMED, RECEIVED, CANCELLED
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  totalAmount     Float    @default(0)
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store           @relation(fields: [storeId], references: [id])
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  receivedQty     Float    @default(0)
  notes           String?

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// EXPENSES

model Expense {
  id              String   @id @default(cuid())
  storeId         String
  description     String
  amount          Float
  category        String   // RENT, SALARIES, UTILITIES, TRANSPORT, MAINTENANCE, SUPPLIES, OTHER
  paidBy          String   // User ID who paid
  paymentMethod   String   @default("CASH") // CASH, MPESA
  status          String   @default("ACTIVE") // ACTIVE, VOIDED
  journalEntryId  String?  // Reference to the created journal entry
  notes           String?
  voidedAt        DateTime?
  voidedBy        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([category])
  @@index([status])
  @@index([paidBy])
  @@index([createdAt])
  @@map("expenses")
}

// MESSAGING

model Message {
  id              String    @id @default(cuid())
  storeId         String
  customerId      String?
  channel         String    @default("WHATSAPP")  // WHATSAPP, SMS, EMAIL, BOTH
  messageType     String    @default("CUSTOM")    // DEBT_REMINDER, PAYMENT_CONFIRMATION, BALANCE_UPDATE, PROMOTION, CUSTOM
  subject         String?
  content         String
  status          String    @default("PENDING")   // PENDING, SENT, DELIVERED, FAILED, READ
  waLink          String?
  sentAt          DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([channel])
  @@index([messageType])
  @@index([status])
  @@index([createdAt])
  @@map("messages")
}

// SYSTEM LOGGING & AUDIT

model SystemLog {
  id              String   @id @default(cuid())
  storeId         String?
  userId          String?
  action          String
  component       String   // POS, INVENTORY, FINANCIAL, AUTH, PAYMENT, RENTAL
  severity        String   @default("INFO") // DEBUG, INFO, WARN, ERROR, CRITICAL
  message         String
  metadata        String?  // JSON string for additional context
  stackTrace      String?
  ipAddress       String?
  createdAt       DateTime @default(now())

  store           Store?   @relation(fields: [storeId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@index([storeId])
  @@index([userId])
  @@index([action])
  @@index([component])
  @@index([severity])
  @@index([createdAt])
  @@map("system_logs")
}

// SYSTEM CONFIGURATION

model SystemConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  isEncrypted     Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("system_configs")
}

model InitializationLog {
  id              String   @id @default(cuid())
  event           String
  details         String?
  executedAt      DateTime @default(now())

  @@map("initialization_logs")
}

// GIFT CARDS & VOUCHERS

model GiftCard {
  id              String   @id @default(cuid())
  storeId         String
  code            String   @unique
  reason          String   // CUSTOMER_LOYALTY, PROMOTION, REFUND_CREDIT, STORE_CREDIT, GIFT, EMPLOYEE_AWARD, COMPLAINT_RESOLUTION, OTHER
  initialBalance  Float
  currentBalance  Float
  currency        String   @default("KES")
  status          String   @default("ACTIVE") // ACTIVE, REDEEMED, EXPIRED, CANCELLED, PARTIALLY_REDEEMED
  recipientName   String?
  recipientPhone  String?
  recipientEmail  String?
  notes           String?
  issuedBy        String?  // User ID who issued the card
  issuedTo        String?  // Customer ID if linked
  expiresAt       DateTime?
  lastRedeemedAt  DateTime?
  autoAdjustItems Boolean  @default(false) // When true, items visibility auto-adjusts based on balance
  isVisible       Boolean  @default(true) // Visibility toggle - auto-adjusts when balance reaches 0
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  issuedByUser    User?     @relation("IssuedByUser", fields: [issuedBy], references: [id])
  issuedToCustomer Customer? @relation("IssuedToCustomer", fields: [issuedTo], references: [id])
  redemptions     GiftCardRedemption[]

  @@index([storeId])
  @@index([code])
  @@index([status])
  @@index([issuedTo])
  @@index([reason])
  @@map("gift_cards")
}

model GiftCardRedemption {
  id              String   @id @default(cuid())
  giftCardId      String
  transactionId   String?  // Link to sales transaction if redeemed against a sale
  amount          Float
  redeemedBy      String?  // User ID who processed the redemption
  notes           String?
  createdAt       DateTime @default(now())

  giftCard        GiftCard          @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction? @relation(fields: [transactionId], references: [id])

  @@index([giftCardId])
  @@index([transactionId])
  @@map("gift_card_redemptions")
}

// VOUCHERS & CAMPAIGNS

model Voucher {
  id              String   @id @default(cuid())
  storeId         String
  code            String   @unique
  name            String
  voucherType     String   @default("FIXED") // FIXED, PERCENTAGE, FREE_PRODUCT, BUNDLE
  value           Float
  description     String?
  minimumPurchase Float    @default(0)
  maxDiscount     Float?
  freeProductId   String?
  maxUses         Int      @default(1)
  currentUses     Int      @default(0)
  maxUsesPerUser  Int      @default(1)
  startDate       DateTime @default(now())
  endDate         DateTime?
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, EXPIRED, CANCELLED
  campaignId      String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign        VoucherCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  redemptions     VoucherRedemption[]

  @@index([storeId])
  @@index([code])
  @@index([status])
  @@index([campaignId])
  @@map("vouchers")
}

model VoucherCampaign {
  id              String   @id @default(cuid())
  storeId         String
  name            String
  campaignType    String   @default("PROMOTION") // PROMOTION, SEASONAL, LOYALTY, REFERRAL, FLASH_SALE
  description     String?
  startDate       DateTime @default(now())
  endDate         DateTime?
  budget          Float    @default(0)
  spentAmount     Float    @default(0)
  targetAudience  String?
  status          String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  totalRedemptions Int    @default(0)
  totalRevenue    Float    @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vouchers        Voucher[]

  @@index([storeId])
  @@index([status])
  @@map("voucher_campaigns")
}

model VoucherRedemption {
  id              String   @id @default(cuid())
  voucherId       String
  transactionId   String?
  redeemedBy      String?  // Customer name or ID
  originalTotal   Float    @default(0)
  discountAmount  Float    @default(0)
  finalTotal      Float    @default(0)
  createdAt       DateTime @default(now())

  voucher         Voucher           @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction? @relation(fields: [transactionId], references: [id])

  @@index([voucherId])
  @@index([transactionId])
  @@map("voucher_redemptions")
}

// SHIFT MANAGEMENT

model Shift {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  user              User      @relation(fields: [userId], references: [id])
  storeId           String    @map("store_id")
  store             Store     @relation(fields: [storeId], references: [id])
  startedAt         DateTime  @map("started_at") @default(now())
  endedAt           DateTime? @map("ended_at")
  startingCash      Float     @map("starting_cash") @default(0)
  endingCash        Float?    @map("ending_cash")
  countedCash       Float?    @map("counted_cash")
  cashDifference    Float?    @map("cash_difference")
  totalSales        Float     @map("total_sales") @default(0)
  totalTransactions Int       @map("total_transactions") @default(0)
  status            String    @default("ACTIVE") // ACTIVE, ENDED
  notes             String?
  createdAt         DateTime  @map("created_at") @default(now())
  updatedAt         DateTime  @map("updated_at") @updatedAt

  @@index([storeId])
  @@index([userId])
  @@index([status])
  // Composite multi-tenant performance index (ISO 27001: scoped storeId + time range)
  @@index([storeId, createdAt])
  @@map("shifts")
}

// INVOICES & QUOTATIONS

model Invoice {
  id              String   @id @default(cuid())
  storeId         String
  invoiceNumber   String   @unique
  invoiceType     String   @default("INVOICE") // INVOICE, QUOTATION, PROFORMA, CREDIT_NOTE, DEBIT_NOTE
  customerId      String?
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  issueDate       DateTime @default(now())
  dueDate         DateTime?
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, INVOICED, PAID, CANCELLED, EXPIRED
  notes           String?
  terms           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]

  @@index([storeId])
  @@index([invoiceNumber])
  @@index([invoiceType])
  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  productId       String?
  productName     String
  description     String?
  quantity        Float
  unitType        String   @default("PIECE")
  pricePerUnit    Float
  discountPercent Float    @default(0)
  taxRate         Float    @default(16)
  lineTotal       Float    @default(0)

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

// DELIVERY NOTES

model DeliveryNote {
  id              String    @id @default(cuid())
  storeId         String
  transactionId   String?   @unique
  deliveryNumber  String    @unique
  customerId      String?
  customerName    String
  customerPhone   String?
  deliveryAddress String?
  driverName      String?
  vehicleNumber   String?
  status          String    @default("PENDING") // PENDING, IN_TRANSIT, DELIVERED, CANCELLED
  scheduledDate   DateTime?
  deliveredAt     DateTime?
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transaction     SalesTransaction? @relation(fields: [transactionId], references: [id])
  items           DeliveryNoteItem[]

  @@index([storeId])
  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  productId       String?
  productName     String
  quantity        Float
  unitType        String   @default("PIECE")
  notes           String?

  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product         Product?     @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
  @@map("delivery_note_items")
}

// ── SECURITY & AUDIT ──────────────────────────────────────────────────────────
model SecurityEvent {
  id            String   @id @default(cuid())
  eventType     String   // RATE_LIMITED, CSRF_FAILED, BRUTE_FORCE, INVALID_INPUT, SUSPICIOUS_ACTIVITY, ACCOUNT_LOCKED, SESSION_HIJACK_ATTEMPT, UNAUTHORIZED_ACCESS
  severity      String   @default("WARN") // DEBUG, INFO, WARN, ERROR, CRITICAL
  ipAddress     String?
  userId        String?
  storeId       String?
  resource      String?  // Which resource was targeted
  action        String?  // What action was attempted
  details       String?  // JSON string with additional context
  userAgent     String?
  blocked       Boolean  @default(false) // Was the request blocked?
  createdAt     DateTime @default(now())

  @@index([eventType])
  @@index([ipAddress])
  @@index([userId])
  @@index([severity])
  @@index([createdAt])
  @@index([blocked])
  @@map("security_events")
}
